{
  "name": "Button",
  "description": "Action component with variants, icons, and clipboard support",
  "props": {
    "text": {
      "type": "string",
      "required": false,
      "description": "Button label text.",
      "default": "Button1"
    },
    "rightText": {
      "type": "string",
      "required": false,
      "description": "Optional secondary text, rendered at the far right inside the text area."
    },
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Visual style variant",
      "options": [
        "default",
        "primary",
        "secondary",
        "accent",
        "outline",
        "ghost",
        "destructive",
        "suggestion"
      ],
      "default": "default"
    },
    "icon": {
      "type": "string",
      "required": false,
      "description": "Icon (string from registry, ReactNode, or SVG element)."
    },
    "iconPosition": {
      "type": "enum",
      "required": false,
      "description": "Icon position relative to text.",
      "options": [
        "left",
        "right"
      ],
      "default": "left"
    },
    "iconOnly": {
      "type": "boolean",
      "required": false,
      "description": "Icon-only mode (no text, square button).",
      "default": false
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "loading": {
      "type": "boolean",
      "required": false,
      "description": "Loading state (shows spinner, dims text)."
    },
    "stretchText": {
      "type": "boolean",
      "required": false,
      "description": "Stretch text area (flex:1)."
    },
    "fullWidth": {
      "type": "boolean",
      "required": false,
      "description": "Full width button.",
      "default": true
    },
    "align": {
      "type": "enum",
      "required": false,
      "description": "Text alignment.",
      "options": [
        "left",
        "right",
        "center"
      ],
      "default": null
    },
    "level": {
      "type": "number",
      "required": false,
      "description": "Nesting level for option-like rows: 0..9"
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Membrane spacing around the button.",
      "default": true
    },
    "copyText": {
      "type": "string",
      "required": false,
      "description": "Copy text to clipboard on click (Clipboard integration).",
      "default": null
    },
    "onCopied": {
      "type": "function",
      "required": false,
      "description": "Callback when copy succeeds."
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Custom children (overrides text/icon rendering).",
      "default": null
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "text": "Button"
      }
    },
    {
      "name": "Primary",
      "props": {
        "text": "Primary",
        "variant": "primary"
      }
    },
    {
      "name": "Secondary",
      "props": {
        "text": "Secondary",
        "variant": "secondary"
      }
    },
    {
      "name": "Accent",
      "props": {
        "text": "Accent",
        "variant": "accent"
      }
    },
    {
      "name": "Outline",
      "props": {
        "text": "Outline",
        "variant": "outline"
      }
    },
    {
      "name": "Ghost",
      "props": {
        "text": "Ghost",
        "variant": "ghost"
      }
    },
    {
      "name": "Destructive",
      "props": {
        "text": "Delete",
        "variant": "destructive"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "text": "Disabled",
        "disabled": true
      }
    },
    {
      "name": "Full Width",
      "props": {
        "text": "Full Width",
        "fullWidth": true
      }
    }
  ],
  "behavior": {
    "loading": "Loading state shows a spinner and blocks activation with native disabled."
  },
  "keyboard": {
    "Enter": {
      "action": "activate"
    },
    "Space": {
      "action": "activate"
    }
  },
  "aria": {
    "role": "button",
    "states": [
      "aria-busy=true when loading"
    ]
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "icon",
      "text"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "icon": {
        "slot": "icon",
        "parent": "root"
      },
      "text": {
        "slot": "text",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-control-pad-left",
      "--uf-control-pad-right",
      "--uf-button-focus-ring-width",
      "--uf-button-outline-width",
      "--uf-button-bg",
      "--uf-button-fg",
      "--uf-button-hover-bg",
      "--uf-button-hover-fg",
      "--uf-button-ring-color",
      "--uf-icon-only-size",
      "--face-runtime-option-level",
      "--uf-interactive-weight",
      "--uf-spinner-size",
      "--uf-spinner-size-sm",
      "--uf-spinner-border-width",
      "--uf-spinner-border-width-sm"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-control-line-height",
      "--uf-control-letter-spacing",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-font-weight",
      "--uf-radius",
      "--uf-membrane",
      "--uf-option-indent",
      "--uf-color-fg",
      "--uf-color-bg",
      "--uf-color-primary",
      "--uf-color-primary-fg",
      "--uf-color-accent",
      "--uf-color-accent-fg",
      "--uf-color-hover-bg",
      "--uf-color-active-bg",
      "--uf-color-destructive",
      "--uf-color-destructive-soft",
      "--uf-color-disabled-opacity",
      "--uf-motion-duration-emphasis",
      "--uf-motion-duration-spin",
      "--uf-motion-iteration-indefinite",
      "--uf-motion-ease-emphasized",
      "--uf-motion-ease-linear"
    ],
    "notes": [
      "Variants set component foreground/background tokens on the root and consume shared control geometry.",
      "Hover font-weight feedback uses --uf-interactive-weight and loading spinner geometry/motion consume shared Face UI tokens.",
      "Use Text for pure typography; Button text is action copy inside an interactive control."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Explicit user action trigger",
      "Form submission",
      "Navigation trigger",
      "Destructive action confirmation"
    ],
    "whenNotToUse": [
      "Pure text display (use Text)",
      "Binary toggle (use Switcher)",
      "Selection among peers (use Radio/Tabs)",
      "Navigation link (use anchor or Navigation)"
    ],
    "alternatives": [
      "Text",
      "Switcher",
      "Radio",
      "Tabs"
    ],
    "context": "both"
  }
}
