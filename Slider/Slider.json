{
  "name": "Slider",
  "description": "Range input with single or multiple thumbs",
  "props": {
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Simple machine-driven slider or the advanced legacy slider.",
      "options": ["simple", "advanced"],
      "default": "simple"
    },
    "value": {
      "type": "array",
      "required": false,
      "description": "Current value(s). Single thumb = [n], range = [min, max]."
    },
    "defaultValue": {
      "type": "array",
      "required": false,
      "description": "Uncontrolled initial value(s)."
    },
    "scalarValue": {
      "type": "number",
      "required": false,
      "description": "Legacy scalar value for the advanced slider."
    },
    "min": {
      "type": "number",
      "required": false,
      "description": "Minimum value.",
      "default": 0
    },
    "max": {
      "type": "number",
      "required": false,
      "description": "Maximum value.",
      "default": 100
    },
    "step": {
      "type": "number",
      "required": false,
      "description": "Step increment.",
      "default": 1
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Orientation.",
      "options": ["horizontal", "vertical"],
      "default": "horizontal"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label content.",
      "default": null
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when value changes."
    },
    "onChange": {
      "type": "function",
      "required": false,
      "description": "Legacy scalar callback for the advanced slider."
    },
    "leading": {
      "type": "enum",
      "required": false,
      "description": "Leading content mode for the advanced slider.",
      "options": ["none", "icon", "text", "iconText"],
      "default": "none"
    },
    "leadingIcon": {
      "type": "string",
      "required": false,
      "description": "Leading icon name for the advanced slider."
    },
    "leadingText": {
      "type": "string",
      "required": false,
      "description": "Leading text for the advanced slider."
    },
    "crop": {
      "type": "boolean",
      "required": false,
      "description": "Enable crop handles in the advanced slider.",
      "default": false
    },
    "defaultCropRange": {
      "type": "object",
      "required": false,
      "description": "Uncontrolled initial crop range for the advanced slider."
    },
    "cropRange": {
      "type": "object",
      "required": false,
      "description": "Controlled crop range for the advanced slider."
    },
    "cropLocksValue": {
      "type": "boolean",
      "required": false,
      "description": "Clamp the value to the crop range.",
      "default": true
    },
    "onCropChange": {
      "type": "function",
      "required": false,
      "description": "Called when the crop range changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": { "defaultValue": [50] }
    },
    {
      "name": "Range",
      "props": { "defaultValue": [20, 80], "label": "Price range" }
    },
    {
      "name": "Advanced",
      "props": { "variant": "advanced", "defaultValue": [42], "leading": "text", "leadingText": "Zoom" }
    },
    {
      "name": "Crop",
      "props": {
        "variant": "advanced",
        "defaultValue": [40],
        "crop": true,
        "defaultCropRange": { "min": 20, "max": 80 },
        "cropLocksValue": true,
        "leading": "text",
        "leadingText": "Crop"
      }
    },
    {
      "name": "Disabled",
      "props": { "defaultValue": [30], "disabled": true }
    }
  ],
  "behavior": {
    "rovingFocus": false
  },
  "keyboard": {
    "ArrowRight": { "action": "increment", "condition": "horizontal" },
    "ArrowLeft": { "action": "decrement", "condition": "horizontal" },
    "ArrowUp": { "action": "increment", "condition": "vertical" },
    "ArrowDown": { "action": "decrement", "condition": "vertical" },
    "Home": { "action": "setMin" },
    "End": { "action": "setMax" },
    "PageUp": { "action": "incrementLarge" },
    "PageDown": { "action": "decrementLarge" }
  },
  "aria": {
    "role": "slider",
    "required": ["aria-valuemin", "aria-valuemax", "aria-valuenow", "aria-label"]
  },
  "composition": {
    "required": ["root", "track", "range", "thumb"],
    "recommended": ["label", "output"],
    "parts": {
      "root": { "slot": "root" },
      "label": { "slot": "label", "parent": "root" },
      "track": { "slot": "track", "parent": "root" },
      "range": { "slot": "range", "parent": "track" },
      "thumb": { "slot": "thumb", "parent": "track", "multiple": true },
      "output": { "slot": "output", "parent": "root" }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-slider-track-hit-size",
      "--uf-slider-line-size",
      "--uf-slider-thumb-size",
      "--uf-slider-row-gap",
      "--uf-slider-leading-gap",
      "--uf-slider-body-basis",
      "--uf-slider-edge-gap",
      "--uf-slider-thumb-w-fallback",
      "--uf-slider-crop-thumb-pad-fallback",
      "--uf-slider-crop-marker-w",
      "--uf-slider-crop-marker-h",
      "--uf-slider-crop-allowed-expand",
      "--face-runtime-slider-t",
      "--face-runtime-slider-crop-left-x",
      "--face-runtime-slider-crop-right-x",
      "--face-runtime-slider-crop-thumb-pad",
      "--face-runtime-slider-thumb-w"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-gap",
      "--uf-control-line-height",
      "--uf-membrane",
      "--uf-radius-full",
      "--uf-color-fg",
      "--uf-color-hover-bg",
      "--uf-color-border",
      "--uf-motion-duration-short",
      "--uf-motion-ease-standard"
    ],
    "notes": [
      "Simple slider track, range and thumbs are tokenized through shared control, space, membrane, radius and color fallbacks.",
      "Simple thumb hover feedback consumes shared Face UI motion tokens.",
      "Advanced slider exposes private runtime geometry via --face-runtime-slider-* CSS custom properties because thumb width and crop marker positions are measured in React.",
      "Advanced slider still contains small pixel constants for measurement math; migrate them only with interaction regression coverage."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Numeric range input",
      "Volume/brightness control",
      "Price range filter"
    ],
    "whenNotToUse": [
      "Exact number input (use Input type=number)",
      "Few discrete options (use Radio or Select)"
    ],
    "alternatives": ["Input", "Radio", "Select"],
    "context": "both"
  }
}
