{
  "name": "Bar",
  "description": "Toolbar layout component with start/end sections",
  "props": {
    "children": {
      "type": "string",
      "required": false,
      "description": "Bar content (typically BarSection elements).",
      "default": null
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Layout direction.",
      "options": [
        "horizontal",
        "vertical"
      ],
      "default": "horizontal"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Horizontal",
      "props": {
        "orientation": "horizontal"
      }
    },
    {
      "name": "Vertical",
      "props": {
        "orientation": "vertical"
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "toolbar"
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "start",
      "end"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "start": {
        "slot": "start",
        "parent": "root"
      },
      "end": {
        "slot": "end",
        "parent": "root"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Top navigation bar",
      "Bottom action bar",
      "Toolbar with actions"
    ],
    "whenNotToUse": [
      "Side navigation (use Panel)",
      "Tab navigation (use Tabs)"
    ],
    "alternatives": [
      "Navigation",
      "Panel"
    ],
    "context": "app"
  }
}
