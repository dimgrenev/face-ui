{
  "name": "Tree",
  "description": "Hierarchical tree view with expand/collapse and selection",
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Tree node definitions (recursive).",
      "default": [
        {
          "id": "src",
          "label": "src",
          "children": [
            {
              "id": "components",
              "label": "components",
              "children": [
                {
                  "id": "button",
                  "label": "Button.tsx"
                },
                {
                  "id": "input",
                  "label": "Input.tsx"
                }
              ]
            },
            {
              "id": "index",
              "label": "index.ts"
            }
          ]
        },
        {
          "id": "package",
          "label": "package.json"
        },
        {
          "id": "readme",
          "label": "README.md"
        }
      ]
    },
    "expandedIds": {
      "type": "array",
      "required": false,
      "description": "Currently expanded node IDs."
    },
    "defaultExpandedIds": {
      "type": "array",
      "required": false,
      "description": "Uncontrolled initial expanded node IDs."
    },
    "selectedId": {
      "type": "string",
      "required": false,
      "description": "Currently selected node ID."
    },
    "defaultSelectedId": {
      "type": "string",
      "required": false,
      "description": "Uncontrolled initial selected node ID."
    },
    "onExpandedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when expanded nodes change."
    },
    "onSelectedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when selected node changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "With Selection",
      "props": {
        "selectedId": "button"
      }
    }
  ],
  "behavior": {
    "rovingFocus": true,
    "typeahead": true,
    "autoFocusOnOpen": "none"
  },
  "keyboard": {
    "ArrowDown": {
      "action": "focusNextVisible"
    },
    "ArrowUp": {
      "action": "focusPreviousVisible"
    },
    "ArrowRight": {
      "action": "expandOrFocusChild"
    },
    "ArrowLeft": {
      "action": "collapseOrFocusParent"
    },
    "Home": {
      "action": "focusFirst"
    },
    "End": {
      "action": "focusLast"
    },
    "Enter": {
      "action": "select"
    },
    "Space": {
      "action": "select"
    },
    "*": {
      "action": "expandAllSiblings"
    }
  },
  "aria": {
    "role": "tree",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "branch",
      "item"
    ],
    "recommended": [
      "itemIndicator",
      "itemText"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "branch": {
        "slot": "branch",
        "parent": "root",
        "multiple": true
      },
      "item": {
        "slot": "item",
        "parent": "branch",
        "multiple": true
      },
      "itemIndicator": {
        "slot": "itemIndicator",
        "parent": "item"
      },
      "itemText": {
        "slot": "itemText",
        "parent": "item"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-tree-branch-indicator-size"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-gap",
      "--uf-radius",
      "--uf-font-size-sm",
      "--uf-font-weight-bold",
      "--uf-color-fg",
      "--uf-color-hover-bg"
    ],
    "notes": [
      "Tree node rows use Button-compatible geometry; branch indicators use a tree-local size alias.",
      "Expansion/selection state is machine-owned and should not leak styling outside tree data parts."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "File system browser",
      "Hierarchical data display",
      "Nested category navigation"
    ],
    "whenNotToUse": [
      "Flat list (use Table)",
      "Simple nav (use Navigation)"
    ],
    "alternatives": [
      "Table",
      "Navigation",
      "Accordion"
    ],
    "context": "app"
  }
}
