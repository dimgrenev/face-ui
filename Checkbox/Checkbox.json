{
  "name": "Checkbox",
  "description": "Form control for boolean or indeterminate selection",
  "props": {
    "checked": {
      "type": "enum",
      "required": false,
      "description": "Checked state (boolean or 'indeterminate').",
      "options": [
        "indeterminate"
      ]
    },
    "defaultChecked": {
      "type": "enum",
      "required": false,
      "description": "Uncontrolled initial checked state.",
      "options": [
        "indeterminate"
      ],
      "default": false
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "Mark as required.",
      "default": false
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Form field name.",
      "default": ""
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label content.",
      "default": null
    },
    "onCheckedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when checked state changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper (+1px outside control geometry).",
      "default": true
    }
  },
  "states": [
    {
      "name": "Default (Unchecked)",
      "props": {
        "label": "Accept terms"
      }
    },
    {
      "name": "Checked",
      "props": {
        "checked": true,
        "label": "Accept terms"
      }
    },
    {
      "name": "Indeterminate",
      "props": {
        "checked": "indeterminate",
        "label": "Select all"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true,
        "label": "Unavailable"
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "Space": {
      "action": "toggle"
    }
  },
  "aria": {
    "role": "checkbox",
    "required": [
      "aria-checked",
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "control",
      "indicator"
    ],
    "recommended": [
      "label"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "control": {
        "slot": "control",
        "parent": "root"
      },
      "indicator": {
        "slot": "indicator",
        "parent": "control"
      },
      "label": {
        "slot": "label",
        "parent": "root"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Multiple selection from options",
      "Opt-in/consent toggles",
      "Task completion checkmarks"
    ],
    "whenNotToUse": [
      "Single on/off toggle (use Switcher)",
      "Mutually exclusive options (use Radio)"
    ],
    "alternatives": [
      "Switcher",
      "Radio"
    ],
    "context": "both"
  }
}
