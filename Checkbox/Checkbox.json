{
  "name": "Checkbox",
  "props": {
    "checked": {
      "type": "enum",
      "options": [
        "indeterminate"
      ],
      "default": ""
    },
    "defaultChecked": {
      "type": "enum",
      "options": [
        "indeterminate"
      ],
      "default": false
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "label": {
      "type": "string",
      "default": "Checkbox"
    },
    "onCheckedChange": {
      "type": "function",
      "default": ""
    },
    "className": {
      "type": "string",
      "default": ""
    },
    "membrane": {
      "type": "boolean",
      "default": true
    }
  }
}