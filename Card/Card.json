{
  "name": "Card",
  "description": "Content container with title, description, content, and footer",
  "props": {
    "title": {
      "type": "string",
      "required": false,
      "description": "Card title",
      "default": "Card Title"
    },
    "description": {
      "type": "string",
      "required": false,
      "description": "Card description below title",
      "default": "Card description text."
    },
    "content": {
      "type": "string",
      "required": false,
      "description": "Card body content",
      "default": null
    },
    "footer": {
      "type": "string",
      "required": false,
      "description": "Card footer content",
      "default": null
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Membrane spacing",
      "default": true
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Custom children (escape hatch)",
      "default": null
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "title": "Card Title",
        "description": "Card description text."
      }
    },
    {
      "name": "With Content",
      "props": {
        "title": "Settings",
        "content": "Card body content goes here."
      }
    },
    {
      "name": "Full",
      "props": {
        "title": "Card Title",
        "description": "A description.",
        "content": "Main content.",
        "footer": "Footer area"
      }
    },
    {
      "name": "No Membrane",
      "props": {
        "title": "Card",
        "membrane": false
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "region"
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "header",
      "title",
      "description",
      "content",
      "footer"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "header": {
        "slot": "header",
        "parent": "root"
      },
      "title": {
        "slot": "title",
        "parent": "header"
      },
      "description": {
        "slot": "description",
        "parent": "header"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "footer": {
        "slot": "footer",
        "parent": "root"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Grouping related content visually",
      "Dashboard widget container",
      "Settings section wrapper",
      "Content preview block"
    ],
    "whenNotToUse": [
      "Full-page layout container (use page structure)",
      "Interactive list item (use Button with variant)",
      "Modal content (use Modal)"
    ],
    "alternatives": [
      "Accordion",
      "Modal"
    ],
    "context": "both"
  }
}
