{
  "name": "Table",
  "description": "Data table with sorting and row selection",
  "props": {
    "columns": {
      "type": "array",
      "required": false,
      "description": "Column definitions.",
      "default": [
        {
          "id": "name",
          "header": "Name",
          "accessor": "name",
          "sortable": true
        },
        {
          "id": "email",
          "header": "Email",
          "accessor": "email"
        },
        {
          "id": "role",
          "header": "Role",
          "accessor": "role"
        }
      ]
    },
    "rows": {
      "type": "array",
      "required": false,
      "description": "Row data.",
      "default": [
        {
          "id": "1",
          "name": "Alice Johnson",
          "email": "alice@example.com",
          "role": "Admin"
        },
        {
          "id": "2",
          "name": "Bob Smith",
          "email": "bob@example.com",
          "role": "Editor"
        },
        {
          "id": "3",
          "name": "Carol Williams",
          "email": "carol@example.com",
          "role": "Viewer"
        }
      ]
    },
    "rowKey": {
      "type": "string",
      "required": false,
      "description": "Key field on each row, or a function returning a unique key.",
      "default": "id"
    },
    "sortColumn": {
      "type": "string",
      "required": false,
      "description": "Controlled sort column.",
      "default": null
    },
    "sortDirection": {
      "type": "enum",
      "required": false,
      "description": "Controlled sort direction.",
      "options": [
        "asc",
        "desc"
      ],
      "default": "asc"
    },
    "onSortChange": {
      "type": "function",
      "required": false,
      "description": "Callback when sort changes."
    },
    "direction": {
      "type": "function",
      "required": true,
      "description": "direction prop"
    },
    "selectedRows": {
      "type": "array",
      "required": false,
      "description": "Controlled selected row IDs.",
      "default": []
    },
    "onSelectedRowsChange": {
      "type": "function",
      "required": false,
      "description": "Callback when selection changes."
    },
    "selectable": {
      "type": "boolean",
      "required": false,
      "description": "Enable row selection.",
      "default": false
    },
    "showRowNumbers": {
      "type": "boolean",
      "required": false,
      "description": "Show row number column.",
      "default": false
    },
    "stickyHeader": {
      "type": "boolean",
      "required": false,
      "description": "Make header sticky on scroll.",
      "default": true
    },
    "showDividers": {
      "type": "boolean",
      "required": false,
      "description": "Show divider lines between rows.",
      "default": true
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    },
    "getRowId": {
      "type": "function",
      "required": false,
      "description": "Legacy components API alias. Prefer rowKey for new code."
    },
    "onColumnResize": {
      "type": "function",
      "required": false,
      "description": "Callback fired while a resizable column is dragged."
    },
    "resizable": {
      "type": "boolean",
      "required": false,
      "description": "Enable column resizing and fixed table layout.",
      "default": false
    },
    "stickyLastColumn": {
      "type": "boolean",
      "required": false,
      "description": "Keep the last column visually sticky for dense action tables.",
      "default": false
    },
    "onRowClick": {
      "type": "function",
      "required": false,
      "description": "Callback when a row is clicked."
    },
    "onRowMouseEnter": {
      "type": "function",
      "required": false,
      "description": "Callback when mouse enters a row."
    },
    "onRowMouseLeave": {
      "type": "function",
      "required": false,
      "description": "Callback when mouse leaves a row."
    },
    "activeRowId": {
      "type": "string",
      "required": false,
      "description": "Row ID to highlight as active (applies `data-active` attribute)."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Enable membrane (tile-like) row styles: rounded corners, hover bg, padding.",
      "default": false
    },
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "Accessible label for the table when there is no visible caption.",
      "default": "Data table"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "resizable": true
      }
    },
    {
      "name": "Selectable",
      "props": {
        "selectable": true
      }
    },
    {
      "name": "Sorted Ascending",
      "props": {
        "sortColumn": "name",
        "sortDirection": "asc"
      }
    },
    {
      "name": "Sorted Descending",
      "props": {
        "sortColumn": "name",
        "sortDirection": "desc"
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "ArrowDown": {
      "action": "focusNextRow"
    },
    "ArrowUp": {
      "action": "focusPreviousRow"
    },
    "Space": {
      "action": "toggleRowSelection",
      "condition": "selectable"
    }
  },
  "aria": {
    "role": "table",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "header",
      "body",
      "row",
      "cell"
    ],
    "recommended": [
      "headerCell",
      "sortIndicator"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "header": {
        "slot": "header",
        "parent": "root"
      },
      "headerCell": {
        "slot": "headerCell",
        "parent": "header",
        "multiple": true
      },
      "sortIndicator": {
        "slot": "sortIndicator",
        "parent": "headerCell"
      },
      "body": {
        "slot": "body",
        "parent": "root"
      },
      "row": {
        "slot": "row",
        "parent": "body",
        "multiple": true
      },
      "cell": {
        "slot": "cell",
        "parent": "row",
        "multiple": true
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-table-row-number-width",
      "--uf-table-resize-hit-width",
      "--uf-table-resize-line-offset-x",
      "--uf-table-resize-line-inset-y",
      "--uf-table-divider-width",
      "--uf-table-membrane-cell-pad-x",
      "--uf-table-sort-icon-gap"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-control-line-height",
      "--uf-control-pad-text",
      "--uf-membrane",
      "--uf-font-size-xs",
      "--uf-font-weight-bold",
      "--uf-radius",
      "--uf-color-bg",
      "--uf-color-fg",
      "--uf-color-border",
      "--uf-color-hover-bg",
      "--uf-motion-duration-emphasis",
      "--uf-motion-ease-emphasized"
    ],
    "notes": [
      "Table cell/header text is rendered through Text wrappers to keep typography centralized.",
      "Resizable/sticky compatibility props map to table component tokens, and membrane row emphasis uses shared Face UI motion tokens."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Structured data display",
      "Sortable/filterable data lists",
      "CRUD data management"
    ],
    "whenNotToUse": [
      "Simple key-value pairs (use Text)",
      "Card-based layouts (use Card grid)"
    ],
    "alternatives": [
      "Card"
    ],
    "context": "both"
  }
}
