{
  "name": "Upload",
  "description": "File upload with drag-and-drop support",
  "props": {
    "accept": {
      "type": "string",
      "required": false,
      "description": "Accepted file types (e.g. \"image/*\", \".pdf,.doc\").",
      "default": ""
    },
    "multiple": {
      "type": "boolean",
      "required": false,
      "description": "Allow multiple file selection.",
      "default": false
    },
    "maxSize": {
      "type": "number",
      "required": false,
      "description": "Maximum file size in bytes. 0 = unlimited.",
      "default": 0
    },
    "maxFiles": {
      "type": "number",
      "required": false,
      "description": "Maximum number of files. 0 = unlimited.",
      "default": 0
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "files": {
      "type": "array",
      "required": false,
      "description": "Controlled file list."
    },
    "onFilesChange": {
      "type": "function",
      "required": false,
      "description": "Callback when files change."
    },
    "onReject": {
      "type": "function",
      "required": false,
      "description": "Callback when files are rejected."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Images Only",
      "props": {
        "accept": "image/*"
      }
    },
    {
      "name": "Multiple",
      "props": {
        "multiple": true
      }
    },
    {
      "name": "Limited",
      "props": {
        "multiple": true,
        "maxFiles": 3,
        "maxSize": 5242880
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "Enter": {
      "action": "openFilePicker"
    },
    "Space": {
      "action": "openFilePicker"
    }
  },
  "aria": {
    "role": "button",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "dropzone"
    ],
    "recommended": [
      "label",
      "fileList"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "dropzone": {
        "slot": "dropzone",
        "parent": "root"
      },
      "label": {
        "slot": "label",
        "parent": "dropzone"
      },
      "fileList": {
        "slot": "fileList",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [],
    "semanticFallbacks": [
      "--uf-radius",
      "--uf-radius-md",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg"
    ],
    "notes": [
      "Upload labels, hints, file names and file sizes render through Text; file picker and remove actions render through Button.",
      "accept, maxSize, maxFiles and file metadata are validation/product data and intentionally outside visual token ownership."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "File upload with drag-and-drop",
      "Image upload with preview",
      "Document attachment"
    ],
    "whenNotToUse": [
      "Text input (use Input)",
      "URL input (use Input)"
    ],
    "alternatives": [
      "Input"
    ],
    "context": "both"
  }
}
