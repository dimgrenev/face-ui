{
  "name": "Steps",
  "description": "Step-by-step wizard navigation",
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Step definitions.",
      "default": [
        {
          "label": "Account",
          "content": "Create your account credentials."
        },
        {
          "label": "Profile",
          "content": "Fill in your profile details."
        },
        {
          "label": "Review",
          "content": "Review and confirm your information."
        }
      ]
    },
    "step": {
      "type": "number",
      "required": false,
      "description": "Current step index (0-based)."
    },
    "defaultStep": {
      "type": "number",
      "required": false,
      "description": "Uncontrolled initial step index.",
      "default": 0
    },
    "linear": {
      "type": "boolean",
      "required": false,
      "description": "Linear mode: prevents skipping steps.",
      "default": true
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable the entire steps navigation.",
      "default": false
    },
    "onStepChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the active step changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "step": 0
      }
    },
    {
      "name": "Second Step",
      "props": {
        "step": 1
      }
    },
    {
      "name": "Non-Linear",
      "props": {
        "step": 0,
        "linear": false
      }
    },
    {
      "name": "Disabled",
      "props": {
        "step": 0,
        "disabled": true
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "ArrowRight": {
      "action": "focusNextStep"
    },
    "ArrowLeft": {
      "action": "focusPreviousStep"
    }
  },
  "aria": {
    "role": "list",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "item",
      "trigger",
      "content"
    ],
    "recommended": [
      "indicator",
      "separator"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "item": {
        "slot": "item",
        "parent": "root",
        "multiple": true
      },
      "trigger": {
        "slot": "trigger",
        "parent": "item"
      },
      "indicator": {
        "slot": "indicator",
        "parent": "trigger"
      },
      "separator": {
        "slot": "separator",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "item"
      }
    }
  },
  "tokenMapping": {
    "component": [],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-gap",
      "--uf-control-font-size",
      "--uf-radius",
      "--uf-font-weight-bold",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg"
    ],
    "notes": [
      "Steps intentionally uses shared control geometry and Text instead of a dedicated component token namespace.",
      "Step content strings route through Text; indicators use compact text glyphs."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Multi-step wizard progress",
      "Onboarding flow indicator",
      "Process status display"
    ],
    "whenNotToUse": [
      "Tab-like content switching (use Tabs)",
      "Simple progress bar (use Progress)"
    ],
    "alternatives": [
      "Tabs",
      "Progress"
    ],
    "context": "both"
  }
}
