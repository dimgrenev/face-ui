{
  "name": "Scroll",
  "description": "Scroll area with custom scrollbar styling hooks",
  "props": {
    "children": {
      "type": "string",
      "required": true,
      "description": "Content to make scrollable.",
      "default": "Scrollable content — Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum."
    },
    "type": {
      "type": "enum",
      "required": false,
      "description": "When scrollbars are visible.",
      "options": [
        "auto",
        "always",
        "hover",
        "scroll"
      ],
      "default": "auto"
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Which axes can scroll.",
      "options": [
        "vertical",
        "horizontal",
        "both"
      ],
      "default": "vertical"
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    },
    "height": {
      "type": "number",
      "required": false,
      "description": "Viewport height.",
      "default": 160
    },
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "Accessible label for the scrollable region.",
      "default": "Scrollable content"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Always Visible",
      "props": {
        "type": "always"
      }
    },
    {
      "name": "Horizontal",
      "props": {
        "orientation": "horizontal"
      }
    },
    {
      "name": "Both Axes",
      "props": {
        "orientation": "both"
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "region",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "viewport"
    ],
    "recommended": [
      "scrollbar",
      "thumb"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "viewport": {
        "slot": "viewport",
        "parent": "root"
      },
      "scrollbar": {
        "slot": "scrollbar",
        "parent": "root"
      },
      "thumb": {
        "slot": "thumb",
        "parent": "scrollbar"
      }
    }
  },
  "tokenMapping": {
    "component": [],
    "semanticFallbacks": [
      "--uf-control-pad-y",
      "--uf-control-pad-text"
    ],
    "notes": [
      "Scroll currently owns viewport padding and clipping only; native scrollbar visuals are browser-owned.",
      "height is a layout input and remains product data rather than a visual token."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Custom scrollable areas",
      "Virtualized long lists",
      "Horizontal scroll containers"
    ],
    "whenNotToUse": [
      "Standard page scroll",
      "Full-page layout"
    ],
    "alternatives": [],
    "context": "app"
  }
}
