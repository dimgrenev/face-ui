{
  "name": "Avatar",
  "description": "User identity display with image and fallback initials",
  "props": {
    "src": {
      "type": "string",
      "required": false,
      "description": "Image source URL.",
      "default": ""
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "User name (used for initials fallback and alt text).",
      "default": ""
    },
    "fallback": {
      "type": "string",
      "required": false,
      "description": "Custom fallback content when image is unavailable.",
      "default": null
    },
    "fallbackDelayMs": {
      "type": "number",
      "required": false,
      "description": "Delay in ms before showing fallback (gives image time to load).",
      "default": 0
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "className prop"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "name": "John Doe"
      }
    },
    {
      "name": "With Image",
      "props": {
        "src": "https://i.pravatar.cc/150?u=avatar",
        "name": "Jane Smith"
      }
    },
    {
      "name": "Initials Only",
      "props": {
        "name": "AB"
      }
    },
    {
      "name": "Custom Fallback",
      "props": {
        "fallback": "?"
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "img",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "image",
      "fallback"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "image": {
        "slot": "image",
        "parent": "root"
      },
      "fallback": {
        "slot": "fallback",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-radius-full",
      "--uf-font-weight-bold",
      "--uf-font-size-sm"
    ],
    "notes": [
      "Avatar uses shared control geometry for compact identity chips.",
      "Fallback initials are generated by the avatar machine; custom fallback content should remain icon/text sized to the same control box."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "User profile image display",
      "Author attribution",
      "Participant list in chat/comments"
    ],
    "whenNotToUse": [
      "Decorative images (use Media)",
      "Logo display (use Media)"
    ],
    "alternatives": [
      "Media",
      "Icon"
    ],
    "context": "both"
  }
}
