{
  "name": "Input",
  "description": "Text input control with focus management and clear button",
  "props": {
    "value": {
      "type": "string",
      "required": false,
      "description": "Current input value."
    },
    "defaultValue": {
      "type": "string",
      "required": false,
      "description": "components API compatibility: uncontrolled initial value.",
      "default": ""
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Native input name."
    },
    "type": {
      "type": "enum",
      "required": false,
      "description": "Input type. 'default' renders a textarea-like free text. Others render <input type=\"...\">.",
      "options": [
        "number",
        "default",
        "text",
        "email",
        "date",
        "password"
      ],
      "default": "default"
    },
    "textLayout": {
      "type": "enum",
      "required": false,
      "description": "Text layout for type=\"default\": 'scroll' (single-line) or 'wrap' (multi-line auto-grow).",
      "options": [
        "scroll",
        "wrap"
      ],
      "default": "scroll"
    },
    "autoGrow": {
      "type": "boolean",
      "required": false,
      "description": "Auto-grow textarea height in wrap mode.",
      "default": true
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable the input.",
      "default": false
    },
    "readOnly": {
      "type": "boolean",
      "required": false,
      "description": "Make the input read-only.",
      "default": false
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label rendered above/beside the input.",
      "default": "Label"
    },
    "description": {
      "type": "string",
      "required": false,
      "description": "Description/help text shown below the input.",
      "default": null
    },
    "error": {
      "type": "string",
      "required": false,
      "description": "Error message shown below the input.",
      "default": ""
    },
    "labelOrientation": {
      "type": "enum",
      "required": false,
      "description": "Label placement relative to the control.",
      "options": [
        "vertical",
        "horizontal"
      ],
      "default": "vertical"
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "description": "Placeholder text.",
      "default": "Type here..."
    },
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "Accessible label when no visible label is provided."
    },
    "controlRole": {
      "type": "string",
      "required": false,
      "description": "Role applied to the native input or textarea control."
    },
    "ariaControls": {
      "type": "string",
      "required": false,
      "description": "Native control aria-controls relationship."
    },
    "ariaActiveDescendant": {
      "type": "string",
      "required": false,
      "description": "Native control aria-activedescendant relationship."
    },
    "ariaAutoComplete": {
      "type": "enum",
      "required": false,
      "description": "Native control aria-autocomplete mode.",
      "options": [
        "none",
        "inline",
        "list",
        "both"
      ]
    },
    "ariaExpanded": {
      "type": "boolean",
      "required": false,
      "description": "Native control aria-expanded state."
    },
    "ariaHasPopup": {
      "type": "string",
      "required": false,
      "description": "Native control aria-haspopup state."
    },
    "spellCheck": {
      "type": "boolean",
      "required": false,
      "description": "Enable/disable spellcheck."
    },
    "icon": {
      "type": "string",
      "required": false,
      "description": "Optional icon inside the control."
    },
    "iconPosition": {
      "type": "enum",
      "required": false,
      "description": "Icon side inside the control. Default: left.",
      "options": [
        "left",
        "right"
      ],
      "default": "left"
    },
    "stretchText": {
      "type": "boolean",
      "required": false,
      "description": "Stretch the input text area so right-side icons pin to the edge.",
      "default": false
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "Show required indicator (*).",
      "default": false
    },
    "autoFocus": {
      "type": "boolean",
      "required": false,
      "description": "Auto-focus on mount."
    },
    "autoComplete": {
      "type": "string",
      "required": false,
      "description": "Native browser autocomplete hint."
    },
    "min": {
      "type": "any",
      "required": false,
      "description": "Min value (for type=\"number\")."
    },
    "max": {
      "type": "any",
      "required": false,
      "description": "Max value (for type=\"number\")."
    },
    "step": {
      "type": "any",
      "required": false,
      "description": "Step value (for type=\"number\")."
    },
    "minLength": {
      "type": "number",
      "required": false,
      "description": "Minimum text length for native validation."
    },
    "maxLength": {
      "type": "number",
      "required": false,
      "description": "Maximum text length for native validation."
    },
    "pattern": {
      "type": "string",
      "required": false,
      "description": "Native validation pattern for single-line inputs."
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the value changes (machine-based)."
    },
    "onChange": {
      "type": "function",
      "required": false,
      "description": "Native onChange handler."
    },
    "onBlur": {
      "type": "function",
      "required": false,
      "description": "Native onBlur handler."
    },
    "onFocus": {
      "type": "function",
      "required": false,
      "description": "Native onFocus handler."
    },
    "onKeyDown": {
      "type": "any",
      "required": false,
      "description": "Native onKeyDown handler."
    },
    "controlRef": {
      "type": "ReactRef",
      "required": false,
      "description": "Ref to the native input or textarea control."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper around control geometry.",
      "default": false
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "className prop"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "label": "Label",
        "placeholder": "Type here..."
      }
    },
    {
      "name": "With Label",
      "props": {
        "label": "Email",
        "placeholder": "you@example.com"
      }
    },
    {
      "name": "With Description",
      "props": {
        "label": "Email",
        "placeholder": "you@example.com",
        "description": "We'll never share your email."
      }
    },
    {
      "name": "With Error",
      "props": {
        "label": "Email",
        "placeholder": "you@example.com",
        "error": "This field is required."
      }
    },
    {
      "name": "Password",
      "props": {
        "type": "password",
        "label": "Password",
        "placeholder": "Enter password"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true,
        "placeholder": "Disabled input"
      }
    },
    {
      "name": "Read Only",
      "props": {
        "readOnly": true,
        "value": "Read only value"
      }
    }
  ],
  "behavior": {
    "autoFocusOnOpen": "none",
    "controlledValue": "External value prop updates sync into the rendered control without emitting onValueChange.",
    "autoGrow": "Wrap textareas auto-grow by default; set autoGrow=false for fixed-height editor surfaces."
  },
  "keyboard": {
    "Escape": {
      "action": "clear",
      "condition": "hasClearButton"
    }
  },
  "aria": {
    "role": "textbox",
    "labeling": [
      "Visible label renders as a native label whose htmlFor matches the generated or provided control id.",
      "ariaLabel is passed to the native control when no visible label is provided.",
      "controlRole and aria* relationship props are passed to the native control so composite search/listbox owners can expose active descendants without imperative DOM mutation."
    ],
    "describedBy": [
      "description id is included in aria-describedby when description is present.",
      "error id is included in aria-describedby when error is present."
    ],
    "states": [
      "disabled controls expose native disabled plus aria-disabled.",
      "readOnly controls expose native readOnly plus aria-readonly.",
      "error controls expose aria-invalid and a polite alert error node."
    ]
  },
  "composition": {
    "required": [
      "root",
      "control"
    ],
    "recommended": [
      "label",
      "description",
      "error",
      "icon"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "label": {
        "slot": "label",
        "parent": "root"
      },
      "control": {
        "slot": "control",
        "parent": "root"
      },
      "icon": {
        "slot": "icon",
        "parent": "control"
      },
      "description": {
        "slot": "description",
        "parent": "root"
      },
      "error": {
        "slot": "error",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-input-icon-size",
      "--uf-input-required-gap"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-radius",
      "--uf-membrane",
      "--uf-font-size-xs",
      "--uf-font-size-sm",
      "--uf-font-weight",
      "--uf-font-weight-bold",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg",
      "--uf-color-destructive",
      "--uf-color-error",
      "--uf-motion-duration-short",
      "--uf-motion-ease-standard"
    ],
    "notes": [
      "Input geometry comes from shared control tokens; label, description and error copy must remain Text-compatible.",
      "Clear-button reveal motion consumes shared Face UI motion tokens.",
      "Required indicator still accepts legacy danger/error fallbacks until color aliases are burned down."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Free text entry in forms",
      "Search input",
      "Password field",
      "Numeric input",
      "Multi-line text area"
    ],
    "whenNotToUse": [
      "Choosing from predefined options (use Select)",
      "Binary yes/no (use Switcher or Checkbox)",
      "Date entry (use DatePicker)"
    ],
    "alternatives": [
      "Select",
      "Switcher",
      "Checkbox",
      "DatePicker"
    ],
    "context": "both"
  }
}
