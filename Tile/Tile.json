{
  "name": "Tile",
  "description": "Interactive row with nested action buttons. Acts as a single clickable surface while allowing independent nested Button actions (like Notion sidebar tabs). Uses div[role=button] to allow valid HTML nesting of child buttons.",
  "props": {
    "text": {
      "type": "string",
      "required": false,
      "description": "Primary label.",
      "default": null
    },
    "rightText": {
      "type": "string",
      "required": false,
      "description": "Optional secondary text at the far right of the label area.",
      "default": null
    },
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Visual variant.",
      "options": [
        "default",
        "ghost",
        "accent"
      ],
      "default": "default"
    },
    "icon": {
      "type": "string",
      "required": false,
      "description": "Icon (string from registry or ReactNode).",
      "default": null
    },
    "iconPosition": {
      "type": "enum",
      "required": false,
      "description": "Icon position relative to text.",
      "options": [
        "left",
        "right"
      ],
      "default": "left"
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "active": {
      "type": "boolean",
      "required": false,
      "description": "Active / selected state.",
      "default": false
    },
    "stretchText": {
      "type": "boolean",
      "required": false,
      "description": "Stretch text area (flex:1).",
      "default": true
    },
    "fullWidth": {
      "type": "boolean",
      "required": false,
      "description": "Full width tile.",
      "default": true
    },
    "align": {
      "type": "enum",
      "required": false,
      "description": "Text alignment.",
      "options": [
        "left",
        "right",
        "center"
      ],
      "default": "left"
    },
    "level": {
      "type": "number",
      "required": false,
      "description": "Nesting level for option-like rows: 0..9",
      "default": null
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Membrane spacing around the tile.",
      "default": true
    },
    "actions": {
      "type": "string",
      "required": false,
      "description": "Nested action buttons. Rendered at the far right; their clicks do not bubble to the tile.",
      "default": null
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Custom children (overrides text/icon rendering)."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "text": "Page title",
        "icon": "file"
      }
    },
    {
      "name": "With actions",
      "props": {
        "text": "Page title",
        "icon": "file",
        "actions": "[Button icon=more] [Button icon=close]"
      }
    },
    {
      "name": "Active",
      "props": {
        "text": "Current page",
        "icon": "file",
        "active": true
      }
    },
    {
      "name": "Disabled",
      "props": {
        "text": "Archived",
        "icon": "file",
        "disabled": true
      }
    },
    {
      "name": "Ghost",
      "props": {
        "text": "Settings",
        "icon": "settings",
        "variant": "ghost"
      }
    },
    {
      "name": "Nested level",
      "props": {
        "text": "Sub-page",
        "icon": "file",
        "level": 1
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "Enter": {
      "action": "activate"
    },
    "Space": {
      "action": "activate"
    }
  },
  "aria": {
    "role": "button"
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "icon",
      "text",
      "actions"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "icon": {
        "slot": "icon",
        "parent": "root"
      },
      "text": {
        "slot": "text",
        "parent": "root"
      },
      "actions": {
        "slot": "actions",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-tile-pad",
      "--uf-tile-level-compensation",
      "--uf-tile-action-size",
      "--uf-tile-focus-ring-width",
      "--uf-tile-bg",
      "--uf-tile-fg",
      "--uf-tile-hover-bg",
      "--face-runtime-option-level"
    ],
    "semanticFallbacks": [
      "--uf-membrane",
      "--uf-control-height",
      "--uf-control-gap",
      "--uf-control-font-size",
      "--uf-control-line-height",
      "--uf-font-weight",
      "--uf-font-weight-bold",
      "--uf-radius",
      "--uf-color-fg",
      "--uf-color-hover-bg",
      "--uf-color-primary",
      "--uf-button-ring-color",
      "--uf-motion-duration-fast",
      "--uf-motion-duration-emphasis",
      "--uf-motion-ease-standard",
      "--uf-motion-ease-emphasized",
      "--uf-option-indent"
    ],
    "notes": [
      "Tile text and rightText render through Text; nested actions should remain Button or UF action components.",
      "Level indentation is driven by --face-runtime-option-level from the level prop and shared option indentation tokens.",
      "Hover font-weight feedback and action reveal transitions consume shared Face UI motion tokens."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Grid item in dashboard",
      "Clickable card-like block",
      "Feature selection grid"
    ],
    "whenNotToUse": [
      "Standard content container (use Card)",
      "Navigation item (use Button)"
    ],
    "alternatives": [
      "Card",
      "Button"
    ],
    "context": "both"
  }
}
