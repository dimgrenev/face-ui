{
  "name": "Drawer",
  "description": "Side-anchored overlay panel for persistent workflows",
  "props": {
    "side": {
      "type": "enum",
      "required": false,
      "description": "Side from which the drawer slides in.",
      "options": [
        "left",
        "right",
        "top",
        "bottom"
      ],
      "default": "right"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "trigger": "Open drawer",
        "title": "Right drawer",
        "description": "Persistent side workflow surface.",
        "children": "Drawer content"
      }
    },
    {
      "name": "Left Side",
      "props": {
        "side": "left",
        "trigger": "Open left drawer",
        "title": "Left drawer"
      }
    },
    {
      "name": "Bottom Sheet",
      "props": {
        "side": "bottom",
        "trigger": "Open bottom sheet",
        "title": "Bottom sheet"
      }
    }
  ],
  "behavior": {
    "focusTrap": true,
    "scrollLock": true,
    "dismissOnEscape": true,
    "dismissOnClickOutside": true,
    "returnFocusOnClose": true,
    "autoFocusOnOpen": "first-focusable"
  },
  "keyboard": {
    "Escape": {
      "action": "close"
    },
    "Tab": {
      "action": "focusTrap",
      "scope": "drawer"
    }
  },
  "aria": {
    "role": "dialog",
    "modal": true,
    "labelledBy": "drawer-title",
    "describedBy": "drawer-description"
  },
  "composition": {
    "required": [
      "root",
      "overlay",
      "content"
    ],
    "recommended": [
      "title",
      "description",
      "close"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "overlay": {
        "slot": "overlay",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "title": {
        "slot": "title",
        "parent": "content"
      },
      "description": {
        "slot": "description",
        "parent": "content"
      },
      "close": {
        "slot": "close",
        "parent": "content"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-modal-side-w-default",
      "--uf-modal-stack-h-default",
      "--uf-modal-side-enter-x",
      "--uf-modal-sheet-inset",
      "--uf-modal-sheet-gap",
      "--face-runtime-modal-w",
      "--face-runtime-modal-h"
    ],
    "semanticFallbacks": [
      "--uf-content-inset",
      "--uf-radius-lg",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-overlay-backdrop-bg",
      "--uf-overlay-backdrop-blur",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-blur",
      "--uf-overlay-surface-shadow",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-z-modal"
    ],
    "notes": [
      "Drawer delegates to Modal with side-specific variant and inherits modal overlay tokens.",
      "Width and height props delegate to Modal private runtime custom properties while default sizing remains in the modal token namespace."
    ]
  },
  "platform": {
    "dialog": true,
    "inert": true
  },
  "usage": {
    "whenToUse": [
      "Side panel with detailed content",
      "Mobile navigation menu",
      "Filters panel"
    ],
    "whenNotToUse": [
      "Centered dialog (use Modal)",
      "Inline expandable (use Accordion)",
      "Quick tooltip info (use Popover)"
    ],
    "alternatives": [
      "Modal",
      "Panel",
      "Popover"
    ],
    "context": "app"
  }
}
