{
  "name": "Navigation",
  "description": "Horizontal or vertical navigation bar with hover dropdowns",
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Navigation item definitions (supports nested dropdowns).",
      "default": [
        {
          "id": "home",
          "label": "Home"
        },
        {
          "id": "products",
          "label": "Products"
        },
        {
          "id": "about",
          "label": "About"
        },
        {
          "id": "contact",
          "label": "Contact"
        }
      ]
    },
    "activeId": {
      "type": "string",
      "required": false,
      "description": "Currently active item ID."
    },
    "defaultActiveId": {
      "type": "string",
      "required": false,
      "description": "Uncontrolled initial active item ID.",
      "default": null
    },
    "onActiveChange": {
      "type": "function",
      "required": false,
      "description": "Callback when active item changes."
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Orientation of the navigation bar.",
      "options": [
        "horizontal",
        "vertical"
      ],
      "default": "horizontal"
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "Surface behavior on compact viewports.",
      "options": [
        "auto",
        "inline",
        "sheet"
      ],
      "default": "auto"
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "Breakpoint where auto surfaces switch to sheet mode."
    },
    "open": {
      "type": "boolean",
      "required": false,
      "description": "Controlled sheet state for compact mode."
    },
    "defaultOpen": {
      "type": "boolean",
      "required": false,
      "description": "Uncontrolled initial sheet state for compact mode.",
      "default": false
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Callback when sheet state changes."
    },
    "trigger": {
      "type": "string",
      "required": false,
      "description": "Optional trigger for compact mode."
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Optional title used in compact sheet header."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "orientation": "horizontal"
      }
    },
    {
      "name": "Vertical",
      "props": {
        "orientation": "vertical"
      }
    }
  ],
  "behavior": {
    "rovingFocus": true
  },
  "keyboard": {
    "ArrowRight": {
      "action": "focusNext",
      "condition": "horizontal"
    },
    "ArrowLeft": {
      "action": "focusPrevious",
      "condition": "horizontal"
    },
    "ArrowDown": {
      "action": "focusNext",
      "condition": "vertical"
    },
    "ArrowUp": {
      "action": "focusPrevious",
      "condition": "vertical"
    },
    "Home": {
      "action": "focusFirst"
    },
    "End": {
      "action": "focusLast"
    }
  },
  "aria": {
    "role": "navigation",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "list",
      "item",
      "link"
    ],
    "recommended": [
      "trigger",
      "content"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "list": {
        "slot": "list",
        "parent": "root"
      },
      "item": {
        "slot": "item",
        "parent": "list",
        "multiple": true
      },
      "link": {
        "slot": "link",
        "parent": "item"
      },
      "trigger": {
        "slot": "trigger",
        "parent": "item"
      },
      "content": {
        "slot": "content",
        "parent": "item"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Primary app navigation",
      "Sidebar menu links",
      "Header nav links"
    ],
    "whenNotToUse": [
      "Content switching within page (use Tabs)",
      "Breadcrumb trail (use Breadcrumb)"
    ],
    "alternatives": [
      "Tabs",
      "Breadcrumb"
    ],
    "context": "app"
  }
}
