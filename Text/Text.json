{
  "name": "Text",
  "description": "Typography component unifying body, heading, label, kbd, and code",
  "props": {
    "text": {
      "type": "string",
      "required": false,
      "description": "Text content.",
      "default": null
    },
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Visual variant.",
      "options": [
        "default",
        "body",
        "heading",
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "label",
        "caption",
        "kbd",
        "code",
        "muted",
        "blockquote"
      ],
      "default": "default"
    },
    "size": {
      "type": "enum",
      "required": false,
      "description": "Text size.",
      "options": [
        "xs",
        "sm",
        "md",
        "lg",
        "xl"
      ],
      "default": null
    },
    "as": {
      "type": "enum",
      "required": false,
      "description": "HTML element to render. Auto-detected from variant if not specified.",
      "options": [
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "label",
        "kbd",
        "code",
        "p",
        "span",
        "div",
        "strong",
        "em",
        "small"
      ],
      "default": null
    },
    "icon": {
      "type": "string",
      "required": false,
      "description": "Icon element (ReactNode).",
      "default": null
    },
    "iconPosition": {
      "type": "enum",
      "required": false,
      "description": "Icon position relative to text.",
      "options": [
        "left",
        "right"
      ],
      "default": "left"
    },
    "inset": {
      "type": "enum",
      "required": false,
      "description": "Padding/height behavior. `control` matches buttons; `none` is flush (no inner padding).",
      "options": [
        "control",
        "none"
      ],
      "default": "control"
    },
    "stretchText": {
      "type": "boolean",
      "required": false,
      "description": "Stretch text area (flex:1).",
      "default": false
    },
    "fullWidth": {
      "type": "boolean",
      "required": false,
      "description": "Full width.",
      "default": false
    },
    "align": {
      "type": "enum",
      "required": false,
      "description": "Text alignment.",
      "options": [
        "left",
        "right",
        "center"
      ],
      "default": "left"
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Membrane spacing.",
      "default": true
    },
    "truncate": {
      "type": "boolean",
      "required": false,
      "description": "Truncate text with ellipsis when it overflows.",
      "default": false
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Custom children (overrides text).",
      "default": null
    },
    "htmlFor": {
      "type": "string",
      "required": false,
      "description": "For label variant: htmlFor attribute."
    }
  },
  "states": [
    {
      "name": "Default (Body)",
      "props": {
        "text": "Body text content.",
        "align": "left",
        "inset": "control"
      }
    },
    {
      "name": "Heading",
      "props": {
        "text": "Heading Text",
        "variant": "heading",
        "inset": "control"
      }
    },
    {
      "name": "Label",
      "props": {
        "text": "Label Text",
        "variant": "label",
        "inset": "control"
      }
    },
    {
      "name": "Caption",
      "props": {
        "text": "Caption text",
        "variant": "caption"
      }
    },
    {
      "name": "Kbd",
      "props": {
        "text": "⌘K",
        "variant": "kbd"
      }
    },
    {
      "name": "Code",
      "props": {
        "text": "const x = 1",
        "variant": "code"
      }
    },
    {
      "name": "Muted",
      "props": {
        "text": "Muted text",
        "variant": "muted"
      }
    },
    {
      "name": "With Icon",
      "props": {
        "text": "With left icon",
        "icon": "search",
        "iconPosition": "left"
      }
    },
    {
      "name": "Stretch + Full Width",
      "props": {
        "text": "Pinned right icon",
        "icon": "right",
        "iconPosition": "right",
        "stretchText": true,
        "fullWidth": true
      }
    },
    {
      "name": "Inset None",
      "props": {
        "text": "Flush text",
        "inset": "none",
        "membrane": false
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "nativeElement": "Uses the semantic element selected by `as` or by the visual variant default; no ARIA role is applied by default.",
    "required": [
      "Use heading variants or `as` for document outline.",
      "Use as=\"label\" or variant=\"label\" with htmlFor for form labels."
    ],
    "notes": [
      "Do not force role=\"text\" on headings, labels, kbd or code."
    ]
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "icon"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "icon": {
        "slot": "icon",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-text-min-height",
      "--uf-text-pad-y",
      "--uf-text-pad-x",
      "--uf-text-inset-none-min-height",
      "--uf-text-inset-none-padding",
      "--uf-text-font-family",
      "--uf-text-size-font-size",
      "--uf-text-font-size",
      "--uf-text-line-height",
      "--uf-text-letter-spacing",
      "--uf-text-font-weight",
      "--uf-text-color",
      "--uf-text-label-font-size",
      "--uf-text-label-line-height",
      "--uf-text-heading-font-size",
      "--uf-text-heading-font-weight",
      "--uf-text-caption-font-size",
      "--uf-text-caption-line-height",
      "--uf-text-caption-color",
      "--uf-text-kbd-height",
      "--uf-text-kbd-pad-x",
      "--uf-text-h1-delta",
      "--uf-text-h2-delta",
      "--uf-text-h3-delta",
      "--uf-text-h4-delta",
      "--uf-text-h5-delta",
      "--uf-text-blockquote-border-width"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-font-family-base",
      "--uf-font-size-xs",
      "--uf-font-size-sm",
      "--uf-font-size-md",
      "--uf-font-size-lg",
      "--uf-font-size-xl",
      "--uf-control-font-size",
      "--uf-control-line-height",
      "--uf-control-letter-spacing",
      "--uf-font-weight",
      "--uf-color-fg",
      "--uf-color-fg-muted"
    ],
    "notes": [
      "Use component tokens for local typography overrides instead of selector-specific !important rules.",
      "`size` writes no inline styles; CSS maps data-size through `--uf-font-size-xs`, `--uf-font-size-sm`, `--uf-font-size-md`, `--uf-font-size-lg` and `--uf-font-size-xl`. `--uf-text-font-size` and `--uf-text-line-height` stay higher-priority local overrides."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "All visible text content",
      "Headings and paragraphs",
      "Labels and captions",
      "Inline code and keyboard shortcuts"
    ],
    "whenNotToUse": [
      "Rich markdown content (use Markdown)",
      "Code blocks (use Code)"
    ],
    "alternatives": [
      "Markdown",
      "Code"
    ],
    "context": "both"
  }
}
