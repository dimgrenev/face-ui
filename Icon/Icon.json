{
  "name": "Icon",
  "description": "Universal icon renderer with provider defaults and multi-source inputs",
  "props": {
    "name": {
      "type": "string",
      "required": false,
      "description": "Registry icon name (backward-compatible).",
      "default": "settings"
    },
    "icon": {
      "type": "any",
      "required": false,
      "description": "Universal icon input: name/component/svg element/url/registry entry."
    },
    "src": {
      "type": "string",
      "required": false,
      "description": "Explicit source URL for external SVG/bitmap icon."
    },
    "size": {
      "type": "number",
      "required": false,
      "description": "Target icon size in px",
      "default": 20
    },
    "square": {
      "type": "boolean",
      "required": false,
      "description": "By default icon is rendered in a square box.",
      "default": true
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "className prop"
    },
    "style": {
      "type": "object",
      "required": false,
      "description": "style prop"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Accessible label. If omitted, icon is decorative.",
      "default": null
    },
    "title": {
      "type": "string",
      "required": false,
      "description": "Optional title element for inline SVG."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "name": "settings",
        "size": 20
      }
    },
    {
      "name": "Large",
      "props": {
        "name": "settings",
        "size": 28
      }
    },
    {
      "name": "Direction Left",
      "props": {
        "name": "left",
        "size": 20
      }
    },
    {
      "name": "Direction Right",
      "props": {
        "name": "right",
        "size": 20
      }
    },
    {
      "name": "Decorative Dot",
      "props": {
        "name": "legend",
        "size": 10
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "img"
  },
  "composition": {
    "required": [
      "root"
    ],
    "parts": {
      "root": {
        "slot": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-icon-size"
    ],
    "semanticFallbacks": [
      "--uf-color-background"
    ],
    "notes": [
      "Icon inherits color through currentColor and does not own palette semantics.",
      "Parent component slots may provide --uf-icon-size, but the Icon API still supports numeric size and IconProvider.size for backward compatibility.",
      "Some built-in glyphs use --uf-color-background for internal knockouts; keep this tied to theme background until icon theming is formalized."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Visual indicators in buttons/menus",
      "Status icons",
      "Navigation icons"
    ],
    "whenNotToUse": [
      "Decorative images (use Media)",
      "User avatars (use Avatar)"
    ],
    "alternatives": [
      "Media",
      "Avatar"
    ],
    "context": "both"
  }
}
