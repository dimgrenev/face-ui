{
  "name": "Select",
  "description": "Option picker with single and multi-select support",
  "props": {
    "options": {
      "type": "array",
      "required": true,
      "description": "Available options.",
      "default": [
        {
          "value": "react",
          "label": "React"
        },
        {
          "value": "vue",
          "label": "Vue"
        },
        {
          "value": "angular",
          "label": "Angular"
        },
        {
          "value": "svelte",
          "label": "Svelte"
        }
      ]
    },
    "value": {
      "type": "array",
      "required": false,
      "description": "Current selected value. String for single, string[] for multiselect."
    },
    "defaultValue": {
      "type": "array",
      "required": false,
      "description": "Uncontrolled initial selected value."
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "description": "Placeholder text when no value is selected.",
      "default": "Select…"
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable the select.",
      "default": false
    },
    "type": {
      "type": "enum",
      "required": false,
      "description": "Selection mode.",
      "options": [
        "select",
        "multiselect"
      ],
      "default": "select"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label rendered above/beside the select."
    },
    "labelOrientation": {
      "type": "enum",
      "required": false,
      "description": "Label placement relative to the control.",
      "options": [
        "vertical",
        "horizontal"
      ],
      "default": "vertical"
    },
    "ariaLabel": {
      "type": "string",
      "required": false,
      "description": "Accessible label (aria-label)."
    },
    "displayValue": {
      "type": "string",
      "required": false,
      "description": "Optional override for the text shown in the trigger."
    },
    "stretchText": {
      "type": "boolean",
      "required": false,
      "description": "Stretch the value area so the arrow pins to the right edge.",
      "default": false
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when value changes."
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Callback when open state changes."
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "Preferred content surface. Auto switches to bottom sheet on compact viewports.",
      "options": [
        "auto",
        "popover",
        "sheet"
      ],
      "default": "auto"
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "Breakpoint where auto surfaces switch from popover to sheet."
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Optional title used for the mobile sheet header."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper around trigger/option geometry.",
      "default": true
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "className prop"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "placeholder": "Choose..."
      }
    },
    {
      "name": "Multiselect",
      "props": {
        "type": "multiselect",
        "placeholder": "Select items..."
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true,
        "placeholder": "Disabled"
      }
    }
  ],
  "behavior": {
    "rovingFocus": true,
    "typeahead": true,
    "dismissOnEscape": true,
    "dismissOnClickOutside": true,
    "autoFocusOnOpen": "first-focusable"
  },
  "keyboard": {
    "ArrowDown": {
      "action": "focusNext",
      "scope": "listbox"
    },
    "ArrowUp": {
      "action": "focusPrevious",
      "scope": "listbox"
    },
    "Enter": {
      "action": "select"
    },
    "Space": {
      "action": "select"
    },
    "Escape": {
      "action": "close"
    },
    "Home": {
      "action": "focusFirst",
      "scope": "listbox"
    },
    "End": {
      "action": "focusLast",
      "scope": "listbox"
    }
  },
  "aria": {
    "role": "combobox",
    "labelledBy": "select-label"
  },
  "composition": {
    "required": [
      "root",
      "trigger",
      "content"
    ],
    "recommended": [
      "item",
      "group",
      "label"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "trigger": {
        "slot": "trigger",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "item": {
        "slot": "item",
        "parent": "content",
        "multiple": true
      },
      "group": {
        "slot": "group",
        "parent": "content",
        "multiple": true
      },
      "label": {
        "slot": "label",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-select-sheet-inset",
      "--uf-select-sheet-gap",
      "--uf-select-content-max-height",
      "--uf-select-panel-pad",
      "--uf-select-sheet-enter-y"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-font-size-sm",
      "--uf-font-weight",
      "--uf-font-weight-bold",
      "--uf-radius",
      "--uf-radius-lg",
      "--uf-membrane",
      "--uf-spacing-1",
      "--uf-z-dropdown",
      "--uf-z-overlay",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-motion-duration-fast",
      "--uf-motion-ease-out",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-border",
      "--uf-color-hover-bg",
      "--uf-overlay-backdrop-bg",
      "--uf-overlay-backdrop-blur",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-border",
      "--uf-overlay-surface-blur",
      "--uf-overlay-surface-shadow",
      "--uf-overlay-enter-y",
      "--uf-overlay-enter-scale"
    ],
    "notes": [
      "Select shares overlay tokens with responsive sheets and popovers; keep trigger and option geometry on control tokens.",
      "Trigger arrow rotation and opacity feedback consume shared Face UI motion tokens.",
      "Option labels should render through Text-compatible label nodes rather than raw typography classes."
    ]
  },
  "platform": {
    "popover": true
  },
  "usage": {
    "whenToUse": [
      "Choosing one option from a predefined list",
      "Form field with enumerated values",
      "Multi-select for tags or categories"
    ],
    "whenNotToUse": [
      "Binary choice (use Switcher)",
      "2-3 visible options (use Radio or SegmentedControl)",
      "Free text input (use Input)"
    ],
    "alternatives": [
      "Radio",
      "SegmentedControl",
      "Switcher",
      "Command"
    ],
    "context": "both"
  }
}
