{
  "name": "Switcher",
  "description": "Binary toggle control with thumb animation",
  "props": {
    "checked": {
      "type": "boolean",
      "required": false,
      "description": "Checked state (controlled)."
    },
    "defaultChecked": {
      "type": "boolean",
      "required": false,
      "description": "Initial checked state (uncontrolled)."
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state.",
      "default": false
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "Mark as required.",
      "default": false
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Form field name.",
      "default": ""
    },
    "value": {
      "type": "string",
      "required": false,
      "description": "Hidden input value when checked.",
      "default": "on"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label content (ReactNode).",
      "default": null
    },
    "text": {
      "type": "string",
      "required": false,
      "description": "Text content (string shorthand, used when `withText` is true)."
    },
    "withText": {
      "type": "boolean",
      "required": false,
      "description": "Show text label alongside the switch.",
      "default": true
    },
    "textWrap": {
      "type": "enum",
      "required": false,
      "description": "Label text overflow: 'truncate' clips with ellipsis, 'wrap' wraps full text.",
      "options": [
        "truncate",
        "wrap"
      ],
      "default": "truncate"
    },
    "onCheckedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when checked state changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper around control geometry.",
      "default": true
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "label": "Dark mode"
      }
    },
    {
      "name": "Checked",
      "props": {
        "checked": true,
        "label": "Enabled"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true,
        "label": "Unavailable"
      }
    },
    {
      "name": "Disabled Checked",
      "props": {
        "checked": true,
        "disabled": true,
        "label": "Locked on"
      }
    }
  ],
  "behavior": {},
  "keyboard": {
    "Space": {
      "action": "toggle"
    },
    "Enter": {
      "action": "toggle"
    }
  },
  "aria": {
    "role": "switch",
    "required": [
      "aria-checked",
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "control",
      "thumb"
    ],
    "recommended": [
      "label"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "control": {
        "slot": "control",
        "parent": "root"
      },
      "thumb": {
        "slot": "thumb",
        "parent": "control"
      },
      "label": {
        "slot": "label",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-switcher-control-size",
      "--uf-switcher-track-inset-block",
      "--uf-switcher-track-inset-inline",
      "--uf-switcher-track-radius",
      "--uf-switcher-thumb-size",
      "--uf-switcher-thumb-top",
      "--uf-switcher-thumb-left",
      "--uf-switcher-thumb-translate-x"
    ],
    "semanticFallbacks": [
      "--uf-control-line-height",
      "--uf-control-height",
      "--uf-control-gap",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-membrane",
      "--uf-radius",
      "--uf-radius-full",
      "--uf-color-fg",
      "--uf-color-bg",
      "--uf-color-hover-bg",
      "--uf-motion-duration-control",
      "--uf-motion-ease-standard"
    ],
    "notes": [
      "Switcher geometry is expressed through component-local aliases over shared control, space and membrane tokens.",
      "Thumb transform and control opacity transitions consume shared Face UI motion tokens.",
      "Visible label copy renders through the Face UI Text primitive while the native label part preserves form-control click semantics."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Binary on/off toggle",
      "Feature enable/disable",
      "Preference toggle"
    ],
    "whenNotToUse": [
      "Multiple choices (use Checkbox)",
      "Mutually exclusive options (use Radio)",
      "Action trigger (use Button)"
    ],
    "alternatives": [
      "Checkbox",
      "Radio",
      "Button"
    ],
    "context": "both"
  }
}
