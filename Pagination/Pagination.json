{
  "name": "Pagination",
  "description": "Compact page navigation with previous/next buttons, current page text and a Menu-backed page picker.",
  "props": {
    "page": {
      "type": "number",
      "required": false,
      "description": "Current page number (1-indexed)."
    },
    "defaultPage": {
      "type": "number",
      "required": false,
      "description": "Uncontrolled initial page number (1-indexed)."
    },
    "total": {
      "type": "number",
      "required": true,
      "description": "Total number of items.",
      "default": 100
    },
    "pageSize": {
      "type": "number",
      "required": false,
      "description": "Number of items per page.",
      "default": 10
    },
    "siblingCount": {
      "type": "number",
      "required": false,
      "description": "Number of sibling pages shown around the current page.",
      "default": 1
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable the entire pagination.",
      "default": false
    },
    "onPageChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the page changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper around each pagination button.",
      "default": true
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Title used for the page picker sheet on compact viewports.",
      "default": "Choose page"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "total": 100,
        "page": 1
      }
    },
    {
      "name": "Middle Page",
      "props": {
        "total": 100,
        "page": 5
      }
    },
    {
      "name": "Large Dataset",
      "props": {
        "total": 500,
        "page": 1,
        "pageSize": 20
      }
    },
    {
      "name": "Disabled",
      "props": {
        "total": 100,
        "page": 1,
        "disabled": true
      }
    }
  ],
  "behavior": {
    "compactNavigation": "Renders Previous/Next Button controls, a Text current-page indicator and an icon-only Menu trigger for page selection.",
    "disabled": "Disables Previous/Next controls and page picker changes when disabled."
  },
  "keyboard": {
    "ArrowRight": {
      "action": "nextPage"
    },
    "ArrowLeft": {
      "action": "previousPage"
    }
  },
  "aria": {
    "role": "navigation",
    "label": "Root nav has aria-label=\"Pagination\".",
    "current": "Current page Text exposes aria-current=\"page\".",
    "controls": "Previous/Next controls use native button semantics through Button; page picker trigger is icon-only with aria-label=\"Choose page\"."
  },
  "composition": {
    "required": [
      "root",
      "prevButton",
      "nextButton",
      "currentPage",
      "pagePicker"
    ],
    "recommended": [
      "pagePickerMenuItems"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "prevButton": {
        "slot": "prevButton",
        "parent": "root"
      },
      "nextButton": {
        "slot": "nextButton",
        "parent": "root"
      },
      "currentPage": {
        "slot": "currentPage",
        "parent": "root"
      },
      "pagePicker": {
        "slot": "pagePicker",
        "parent": "root"
      },
      "pagePickerMenuItems": {
        "slot": "pagePickerMenuItems",
        "parent": "pagePicker",
        "multiple": true
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-icon-only-size"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-radius",
      "--uf-font-weight",
      "--uf-font-weight-bold",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg",
      "--uf-color-primary",
      "--uf-color-primary-fg"
    ],
    "notes": [
      "Pagination uses Button for previous/next and page-picker controls and Text for the current-page indicator.",
      "Compact page-picker sheet behavior inherits Sheet/Modal tokens rather than defining pagination-local overlay tokens."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Table page navigation",
      "Search results paging",
      "Content list navigation"
    ],
    "whenNotToUse": [
      "Infinite scroll content",
      "Few items that fit on one page"
    ],
    "alternatives": [
      "Table"
    ],
    "context": "both"
  }
}
