{
  "name": "DatePicker",
  "description": "Date and time picker with calendar, range selection, and multiple view modes",
  "props": {
    "mode": {
      "type": "enum",
      "required": false,
      "description": "Picker mode: date-only, datetime, time-only, week, month, or year selection.",
      "options": ["date", "datetime", "time", "week", "month", "year"]
    },
    "selection": {
      "type": "enum",
      "required": false,
      "description": "Selection mode: single date or date range.",
      "options": ["single", "range"]
    },
    "views": {
      "type": "array",
      "required": false,
      "description": "Available calendar views the user can navigate between."
    },
    "openTo": {
      "type": "enum",
      "required": false,
      "description": "Initial calendar view when opened.",
      "options": ["month", "year", "day", "hours", "minutes"]
    },
    "value": {
      "type": "any",
      "required": false,
      "description": "Controlled selected date value. Date object or ISO string depending on valueFormat."
    },
    "defaultValue": {
      "type": "any",
      "required": false,
      "description": "Uncontrolled initial date value."
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the selected date changes."
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the picker open state changes."
    },
    "valueFormat": {
      "type": "enum",
      "required": false,
      "description": "Format of the value: native Date object or ISO string.",
      "options": ["date", "iso"]
    },
    "locale": {
      "type": "string",
      "required": false,
      "description": "BCP 47 locale for date formatting and calendar layout (e.g. 'en-US', 'ru-RU')."
    },
    "timezone": {
      "type": "string",
      "required": false,
      "description": "IANA timezone for date calculations (e.g. 'America/New_York')."
    },
    "weekStartsOn": {
      "type": "enum",
      "required": false,
      "description": "First day of the week: 0=Sunday, 1=Monday, etc.",
      "options": ["0", "1", "2", "3", "4", "5", "6"]
    },
    "format": {
      "type": "string",
      "required": false,
      "description": "Display format string for the trigger (e.g. 'MMM dd, yyyy')."
    },
    "min": {
      "type": "any",
      "required": false,
      "description": "Minimum selectable date. Dates before this are disabled."
    },
    "max": {
      "type": "any",
      "required": false,
      "description": "Maximum selectable date. Dates after this are disabled."
    },
    "disabledDates": {
      "type": "array",
      "required": false,
      "description": "Array of specific dates or date ranges to disable."
    },
    "disabledTime": {
      "type": "object",
      "required": false,
      "description": "Time constraints: disabled hours, minutes, or seconds."
    },
    "closeOnSelect": {
      "type": "boolean",
      "required": false,
      "description": "Automatically close the picker after selection."
    },
    "showNow": {
      "type": "boolean",
      "required": false,
      "description": "Show a 'Now' button for quick selection of current date/time."
    },
    "showClear": {
      "type": "boolean",
      "required": false,
      "description": "Show a clear button to reset the selected value."
    },
    "showPresets": {
      "type": "boolean",
      "required": false,
      "description": "Show preset date shortcuts (Today, Yesterday, Last 7 days, etc.)."
    },
    "presets": {
      "type": "array",
      "required": false,
      "description": "Custom preset definitions: { label, value } pairs."
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "Content surface. Auto switches to bottom sheet on compact viewports.",
      "options": ["auto", "popover", "sheet"]
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "Breakpoint where auto surfaces switch from popover to sheet."
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Title for the mobile sheet header."
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Label rendered above/beside the trigger."
    },
    "description": {
      "type": "string",
      "required": false,
      "description": "Help text shown below the trigger."
    },
    "error": {
      "type": "string",
      "required": false,
      "description": "Error message shown below the trigger."
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "Show required indicator (*)."
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable the date picker."
    },
    "readOnly": {
      "type": "boolean",
      "required": false,
      "description": "Make the date picker read-only (shows value but can't change)."
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "description": "Placeholder text when no date is selected."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper (+1px outside trigger geometry)."
    },
    "fullWidth": {
      "type": "boolean",
      "required": false,
      "description": "Stretch to full container width."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "label": "Date",
        "placeholder": "Pick date"
      }
    },
    {
      "name": "Date Range",
      "props": {
        "label": "Date Range",
        "selection": "range",
        "placeholder": "Select range"
      }
    },
    {
      "name": "DateTime",
      "props": {
        "label": "Date & Time",
        "mode": "datetime",
        "placeholder": "Pick date and time"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "label": "Date",
        "disabled": true,
        "placeholder": "Disabled"
      }
    }
  ],
  "behavior": {
    "dismissOnEscape": true,
    "dismissOnClickOutside": true,
    "autoFocusOnOpen": "first-focusable"
  },
  "keyboard": {
    "ArrowLeft": { "action": "previousDay", "scope": "calendar" },
    "ArrowRight": { "action": "nextDay", "scope": "calendar" },
    "ArrowUp": { "action": "previousWeek", "scope": "calendar" },
    "ArrowDown": { "action": "nextWeek", "scope": "calendar" },
    "Enter": { "action": "select" },
    "Space": { "action": "select" },
    "Escape": { "action": "close" },
    "PageUp": { "action": "previousMonth", "scope": "calendar" },
    "PageDown": { "action": "nextMonth", "scope": "calendar" }
  },
  "aria": {
    "role": "combobox",
    "labelledBy": "datepicker-label"
  },
  "composition": {
    "required": ["root", "trigger", "calendar"],
    "recommended": ["header", "day", "monthNav", "presets"],
    "parts": {
      "root": { "slot": "root" },
      "trigger": { "slot": "trigger", "parent": "root" },
      "calendar": { "slot": "calendar", "parent": "root" },
      "header": { "slot": "header", "parent": "calendar" },
      "monthNav": { "slot": "monthNav", "parent": "header" },
      "day": { "slot": "day", "parent": "calendar", "multiple": true },
      "presets": { "slot": "presets", "parent": "root" }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-date-content-max-width",
      "--uf-date-content-max-height",
      "--uf-date-content-viewport-gap",
      "--uf-date-sheet-inset",
      "--uf-date-sheet-gap",
      "--uf-date-panel-pad",
      "--uf-date-sheet-enter-y"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-radius",
      "--uf-membrane",
      "--uf-spacing-1",
      "--uf-spacing-8",
      "--uf-z-dropdown",
      "--uf-z-overlay",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-color-fg",
      "--uf-color-hover-bg",
      "--uf-color-destructive",
      "--uf-color-error",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-blur",
      "--uf-overlay-surface-shadow",
      "--uf-overlay-enter-y",
      "--uf-overlay-enter-scale"
    ],
    "notes": [
      "DatePicker is a Date wrapper; keep token ownership aligned with the Date surface.",
      "Calendar day/month/year controls use Face UI Button/Text internally and inherit their control token contracts."
    ]
  },
  "platform": {
    "popover": true
  },
  "usage": {
    "whenToUse": ["Date input in forms", "Date range selection for filters", "Scheduling and booking interfaces"],
    "whenNotToUse": ["Selecting from recent/known dates (use Select with date options)", "Time-only input without calendar (use Input type=time)"],
    "alternatives": ["Input", "Select"],
    "context": "both"
  }
}
