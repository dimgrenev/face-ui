{
  "name": "Separator",
  "description": "Visual divider for separating content",
  "props": {
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Separator direction",
      "options": [
        "horizontal",
        "vertical"
      ],
      "default": "horizontal"
    },
    "decorative": {
      "type": "boolean",
      "required": false,
      "description": "Whether the separator is purely decorative",
      "default": true
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Membrane spacing",
      "default": true
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Vertical",
      "props": {
        "orientation": "vertical"
      }
    },
    {
      "name": "Semantic",
      "props": {
        "decorative": false
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "separator"
  },
  "composition": {
    "required": [
      "root"
    ],
    "parts": {
      "root": {
        "slot": "root"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Visual divider between content sections",
      "Menu item group divider"
    ],
    "whenNotToUse": [
      "Spacing only (use CSS gap)",
      "Decorative borders (use CSS border)"
    ],
    "alternatives": [],
    "context": "both"
  }
}
