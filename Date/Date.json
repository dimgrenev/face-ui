{
  "name": "Date",
  "description": "Unified date/time picker with multi-view and range support",
  "props": {
    "mode": {
      "type": "enum",
      "required": false,
      "description": "Picker mode: date, datetime, time, week, month or year",
      "options": [
        "date",
        "datetime",
        "time",
        "week",
        "month",
        "year"
      ],
      "default": "date"
    },
    "selection": {
      "type": "enum",
      "required": false,
      "description": "Selection model: single or range",
      "options": [
        "single",
        "range"
      ],
      "default": "single"
    },
    "views": {
      "type": "array",
      "required": false,
      "description": "Allowed views order",
      "default": [
        "day"
      ]
    },
    "openTo": {
      "type": "enum",
      "required": false,
      "description": "Initial opened view",
      "options": [
        "month",
        "year",
        "day",
        "hours",
        "minutes"
      ],
      "default": "day"
    },
    "value": {
      "type": "any",
      "required": false,
      "description": "Controlled value (iso/date/range)"
    },
    "defaultValue": {
      "type": "any",
      "required": false,
      "description": "defaultValue prop",
      "default": null
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "onValueChange prop"
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "onOpenChange prop"
    },
    "valueFormat": {
      "type": "enum",
      "required": false,
      "description": "Value emission format: iso or date",
      "options": [
        "date",
        "iso"
      ],
      "default": "iso"
    },
    "locale": {
      "type": "string",
      "required": false,
      "description": "Formatting locale",
      "default": "en-US"
    },
    "timezone": {
      "type": "string",
      "required": false,
      "description": "Formatting timezone",
      "default": "UTC"
    },
    "weekStartsOn": {
      "type": "enum",
      "required": false,
      "description": "Week start day index",
      "options": [
        "0",
        "1",
        "2",
        "3",
        "4",
        "5",
        "6"
      ],
      "default": 1
    },
    "format": {
      "type": "string",
      "required": false,
      "description": "format prop"
    },
    "min": {
      "type": "any",
      "required": false,
      "description": "min prop",
      "default": null
    },
    "max": {
      "type": "any",
      "required": false,
      "description": "max prop",
      "default": null
    },
    "disabledDates": {
      "type": "array",
      "required": false,
      "description": "disabledDates prop"
    },
    "disabledTime": {
      "type": "object",
      "required": false,
      "description": "disabledTime prop"
    },
    "minutes": {
      "type": "number",
      "required": false,
      "description": "minutes prop"
    },
    "closeOnSelect": {
      "type": "boolean",
      "required": false,
      "description": "Close panel after completing selection",
      "default": true
    },
    "showNow": {
      "type": "boolean",
      "required": false,
      "description": "Show Now action in footer",
      "default": true
    },
    "showClear": {
      "type": "boolean",
      "required": false,
      "description": "Show Clear action in footer",
      "default": true
    },
    "showPresets": {
      "type": "boolean",
      "required": false,
      "description": "Show preset quick actions",
      "default": false
    },
    "presets": {
      "type": "array",
      "required": false,
      "description": "presets prop"
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "surface prop",
      "options": [
        "auto",
        "popover",
        "sheet"
      ],
      "default": "auto"
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "surfaceBreakpoint prop"
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "surfaceTitle prop"
    },
    "label": {
      "type": "string",
      "required": false,
      "description": "Control label",
      "default": "Date"
    },
    "description": {
      "type": "string",
      "required": false,
      "description": "Helper text below control",
      "default": null
    },
    "error": {
      "type": "string",
      "required": false,
      "description": "Error message below control",
      "default": null
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "required prop",
      "default": false
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disable interactions",
      "default": false
    },
    "readOnly": {
      "type": "boolean",
      "required": false,
      "description": "Read-only mode",
      "default": false
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "description": "Trigger placeholder text",
      "default": "Pick date"
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Enable membrane wrapper around trigger",
      "default": true
    },
    "fullWidth": {
      "type": "boolean",
      "required": false,
      "description": "Stretch control to container width",
      "default": true
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "className prop"
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "mode": "date",
        "label": "Date",
        "placeholder": "Pick date",
        "showNow": true,
        "showClear": true
      }
    },
    {
      "name": "DateTime",
      "props": {
        "mode": "datetime",
        "views": [
          "day",
          "hours",
          "minutes"
        ],
        "openTo": "day",
        "label": "Date & Time",
        "value": "2026-03-03T12:30"
      }
    },
    {
      "name": "Time",
      "props": {
        "mode": "time",
        "views": [
          "hours",
          "minutes"
        ],
        "openTo": "hours",
        "label": "Time",
        "value": "2026-03-03T08:15"
      }
    },
    {
      "name": "Range",
      "props": {
        "mode": "date",
        "selection": "range",
        "label": "Date range",
        "showPresets": true,
        "value": {
          "start": "2026-03-03",
          "end": "2026-03-09"
        }
      }
    },
    {
      "name": "Week",
      "props": {
        "mode": "week",
        "selection": "range",
        "label": "Week",
        "value": {
          "start": "2026-03-02",
          "end": "2026-03-08"
        }
      }
    },
    {
      "name": "Month",
      "props": {
        "mode": "month",
        "views": [
          "month",
          "year"
        ],
        "openTo": "month",
        "label": "Month",
        "value": "2026-06-01"
      }
    },
    {
      "name": "Year",
      "props": {
        "mode": "year",
        "views": [
          "year"
        ],
        "openTo": "year",
        "label": "Year",
        "value": "2028-01-01"
      }
    },
    {
      "name": "With Validation",
      "props": {
        "mode": "date",
        "label": "Limited date",
        "min": "2026-03-01",
        "max": "2026-03-31",
        "disabledDates": [
          "2026-03-08",
          "2026-03-15",
          "2026-03-22"
        ],
        "description": "Only March 2026 is selectable",
        "error": null
      }
    },
    {
      "name": "Read Only",
      "props": {
        "mode": "date",
        "label": "Read only date",
        "readOnly": true,
        "value": "2026-03-03"
      }
    }
  ],
  "behavior": {
    "dismissOnEscape": true,
    "dismissOnClickOutside": true,
    "returnFocusOnClose": true,
    "rovingFocus": true
  },
  "keyboard": {
    "Escape": {
      "action": "close"
    },
    "ArrowRight": {
      "action": "nextDay"
    },
    "ArrowLeft": {
      "action": "previousDay"
    },
    "ArrowDown": {
      "action": "nextWeek"
    },
    "ArrowUp": {
      "action": "previousWeek"
    },
    "Enter": {
      "action": "select"
    },
    "Space": {
      "action": "select"
    }
  },
  "aria": {
    "role": "combobox",
    "required": [
      "aria-label",
      "aria-expanded"
    ]
  },
  "composition": {
    "required": [
      "root",
      "trigger",
      "content",
      "calendar"
    ],
    "recommended": [
      "label",
      "description",
      "error"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "label": {
        "slot": "label",
        "parent": "root"
      },
      "trigger": {
        "slot": "trigger",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "calendar": {
        "slot": "calendar",
        "parent": "content"
      },
      "description": {
        "slot": "description",
        "parent": "root"
      },
      "error": {
        "slot": "error",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-date-content-max-width",
      "--uf-date-content-max-height",
      "--uf-date-content-viewport-gap",
      "--uf-date-sheet-inset",
      "--uf-date-sheet-gap",
      "--uf-date-panel-pad",
      "--uf-date-sheet-enter-y"
    ],
    "semanticFallbacks": [
      "--uf-spacing-1",
      "--uf-spacing-8",
      "--uf-membrane",
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-radius",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg",
      "--uf-color-destructive",
      "--uf-color-error",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-shadow",
      "--uf-overlay-surface-blur",
      "--uf-overlay-enter-y",
      "--uf-overlay-enter-scale",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-z-dropdown",
      "--uf-z-overlay"
    ],
    "notes": [
      "Date label, value, description and error text render through Text; actions render through Button.",
      "Popover and sheet surfaces inherit overlay semantic tokens for surface, blur, shadow and motion.",
      "Date values, locale and timezone are product data and intentionally outside visual token ownership."
    ]
  },
  "platform": {
    "popover": true
  },
  "usage": {
    "whenToUse": [
      "Formatted date display",
      "Relative time display"
    ],
    "whenNotToUse": [
      "Date input (use DatePicker)",
      "Calendar view (use Calendar)"
    ],
    "alternatives": [
      "DatePicker",
      "Text"
    ],
    "context": "both"
  }
}
