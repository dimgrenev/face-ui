{
  "name": "Calendar",
  "description": "Standalone date picker grid",
  "props": {
    "value": {
      "type": "object",
      "required": false,
      "description": "Selected date."
    },
    "defaultValue": {
      "type": "object",
      "required": false,
      "description": "Default selected date (uncontrolled)."
    },
    "min": {
      "type": "object",
      "required": false,
      "description": "Minimum selectable date.",
      "default": null
    },
    "max": {
      "type": "object",
      "required": false,
      "description": "Maximum selectable date.",
      "default": null
    },
    "disabledDates": {
      "type": "array",
      "required": false,
      "description": "Array of dates that cannot be selected."
    },
    "locale": {
      "type": "string",
      "required": false,
      "description": "Locale for month and weekday names.",
      "default": "en-US"
    },
    "weekStartsOn": {
      "type": "enum",
      "required": false,
      "description": "First day of the week: 0=Sunday, 1=Monday, etc.",
      "options": [
        "0",
        "1",
        "2",
        "3",
        "4",
        "5",
        "6"
      ],
      "default": 0
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when the selected date changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Monday Start",
      "props": {
        "weekStartsOn": 1
      }
    }
  ],
  "behavior": {
    "rovingFocus": true
  },
  "keyboard": {
    "ArrowRight": {
      "action": "nextDay"
    },
    "ArrowLeft": {
      "action": "previousDay"
    },
    "ArrowDown": {
      "action": "nextWeek"
    },
    "ArrowUp": {
      "action": "previousWeek"
    },
    "Home": {
      "action": "startOfWeek"
    },
    "End": {
      "action": "endOfWeek"
    },
    "PageUp": {
      "action": "previousMonth"
    },
    "PageDown": {
      "action": "nextMonth"
    },
    "Enter": {
      "action": "select"
    },
    "Space": {
      "action": "select"
    }
  },
  "aria": {
    "role": "grid",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "header",
      "grid",
      "cell"
    ],
    "recommended": [
      "prevButton",
      "nextButton",
      "title"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "header": {
        "slot": "header",
        "parent": "root"
      },
      "prevButton": {
        "slot": "prevButton",
        "parent": "header"
      },
      "nextButton": {
        "slot": "nextButton",
        "parent": "header"
      },
      "title": {
        "slot": "title",
        "parent": "header"
      },
      "grid": {
        "slot": "grid",
        "parent": "root"
      },
      "cell": {
        "slot": "cell",
        "parent": "grid",
        "multiple": true
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-calendar-nav-size",
      "--uf-calendar-weekday-height",
      "--uf-calendar-cell-size",
      "--uf-icon-only-size"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-spacing-1",
      "--uf-spacing-2",
      "--uf-membrane",
      "--uf-radius",
      "--uf-font-size",
      "--uf-font-size-xs",
      "--uf-font-size-sm",
      "--uf-font-weight-bold",
      "--uf-color-fg",
      "--uf-color-bg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg"
    ],
    "notes": [
      "Calendar navigation uses Button and Icon; title, weekdays and day labels route through Text/Button surfaces.",
      "Cell sizing is derived from shared control geometry so calendar density follows enterprise control density."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Standalone calendar view",
      "Date display in dashboard",
      "Event scheduling grid"
    ],
    "whenNotToUse": [
      "Date input in forms (use DatePicker)",
      "Simple date display (use Text)"
    ],
    "alternatives": [
      "DatePicker"
    ],
    "context": "app"
  }
}
