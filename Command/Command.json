{
  "name": "Command",
  "description": "Command palette and search component with filtering and keyboard navigation",
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Command item definitions.",
      "default": [
        {
          "id": "copy",
          "label": "Copy",
          "keywords": [
            "clipboard"
          ]
        },
        {
          "id": "paste",
          "label": "Paste",
          "keywords": [
            "clipboard"
          ]
        },
        {
          "id": "cut",
          "label": "Cut"
        },
        {
          "id": "undo",
          "label": "Undo"
        },
        {
          "id": "redo",
          "label": "Redo"
        }
      ]
    },
    "groups": {
      "type": "array",
      "required": false,
      "description": "Group definitions for organizing items.",
      "default": []
    },
    "placeholder": {
      "type": "string",
      "required": false,
      "description": "Placeholder text for the search input.",
      "default": "Search..."
    },
    "value": {
      "type": "string",
      "required": false,
      "description": "Search input value (controlled)."
    },
    "defaultValue": {
      "type": "string",
      "required": false,
      "description": "Uncontrolled initial search input value.",
      "default": ""
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when search value changes."
    },
    "onSelect": {
      "type": "function",
      "required": false,
      "description": "Callback when an item is selected."
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "Shell presentation mode. Auto switches to dialog on compact viewports.",
      "options": [
        "auto",
        "inline",
        "dialog"
      ],
      "default": "auto"
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "Breakpoint where auto surfaces switch from inline to dialog."
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Optional title used for the mobile dialog header."
    },
    "open": {
      "type": "boolean",
      "required": false,
      "description": "Controlled dialog open state (used in dialog surface)."
    },
    "defaultOpen": {
      "type": "boolean",
      "required": false,
      "description": "Uncontrolled initial dialog open state (used in dialog surface).",
      "default": false
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Callback when dialog open state changes."
    },
    "emptyContent": {
      "type": "string",
      "required": false,
      "description": "Content to display when no results match.",
      "default": "No results found."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "placeholder": "Type a command..."
      }
    },
    {
      "name": "Custom Placeholder",
      "props": {
        "placeholder": "Search actions..."
      }
    }
  ],
  "behavior": {
    "rovingFocus": true,
    "typeahead": true,
    "dismissOnEscape": true,
    "autoFocusOnOpen": "first-focusable"
  },
  "keyboard": {
    "ArrowDown": {
      "action": "focusNext",
      "scope": "list"
    },
    "ArrowUp": {
      "action": "focusPrevious",
      "scope": "list"
    },
    "Enter": {
      "action": "select"
    },
    "Escape": {
      "action": "close"
    },
    "Home": {
      "action": "focusFirst",
      "scope": "list"
    },
    "End": {
      "action": "focusLast",
      "scope": "list"
    }
  },
  "aria": {
    "role": "combobox",
    "labelledBy": "command-label"
  },
  "composition": {
    "required": [
      "root",
      "input",
      "list"
    ],
    "recommended": [
      "item",
      "group",
      "empty"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "input": {
        "slot": "input",
        "parent": "root"
      },
      "list": {
        "slot": "list",
        "parent": "root"
      },
      "item": {
        "slot": "item",
        "parent": "list",
        "multiple": true
      },
      "group": {
        "slot": "group",
        "parent": "list",
        "multiple": true
      },
      "empty": {
        "slot": "empty",
        "parent": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-command-border-width",
      "--uf-command-list-max-height",
      "--uf-command-dialog-list-viewport-gap",
      "--uf-command-dialog-enter-y",
      "--uf-command-dialog-inset",
      "--uf-command-dialog-viewport-gap"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-control-font-size",
      "--uf-control-line-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-pad-icon",
      "--uf-control-gap",
      "--uf-content-inset",
      "--uf-membrane",
      "--uf-font-size",
      "--uf-font-size-xs",
      "--uf-font-weight-bold",
      "--uf-radius",
      "--uf-radius-md",
      "--uf-z-overlay",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-color-bg",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-border",
      "--uf-overlay-surface-blur",
      "--uf-overlay-surface-shadow"
    ],
    "notes": [
      "Command combines input, list and dialog surfaces; keep search input geometry on shared control tokens.",
      "Use UF product composites for domain-specific command rows instead of expanding this primitive contract."
    ]
  },
  "platform": {
    "dialog": true,
    "popover": true
  },
  "usage": {
    "whenToUse": [
      "Quick action search with keyboard",
      "Command palette (Cmd+K)",
      "Searchable action list"
    ],
    "whenNotToUse": [
      "Simple value selection (use Select)",
      "Contextual actions on element (use Menu)",
      "Navigation between pages (use Navigation)"
    ],
    "alternatives": [
      "Select",
      "Menu",
      "Navigation"
    ],
    "context": "app"
  }
}
