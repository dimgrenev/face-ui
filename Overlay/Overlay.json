{
  "name": "Overlay",
  "description": "Floating content surface unifying tooltip, popover, and hover card",
  "props": {
    "trigger": {
      "type": "enum",
      "required": false,
      "description": "How the overlay is triggered.",
      "options": [
        "hover",
        "click"
      ],
      "default": "hover"
    },
    "interactive": {
      "type": "boolean",
      "required": false,
      "description": "Whether content is interactive (keeps open on hover).",
      "default": false
    },
    "content": {
      "type": "string",
      "required": false,
      "description": "Content rendered inside the floating surface.",
      "default": "Tooltip text"
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Trigger element (the anchor).",
      "default": "Hover me"
    },
    "open": {
      "type": "boolean",
      "required": false,
      "description": "Controlled open state.",
      "default": false
    },
    "openDelay": {
      "type": "number",
      "required": false,
      "description": "Delay before opening (ms).",
      "default": 200
    },
    "closeDelay": {
      "type": "number",
      "required": false,
      "description": "Delay before closing (ms).",
      "default": 0
    },
    "side": {
      "type": "enum",
      "required": false,
      "description": "Preferred side placement.",
      "options": [
        "top",
        "right",
        "bottom",
        "left"
      ],
      "default": "top"
    },
    "align": {
      "type": "enum",
      "required": false,
      "description": "Alignment along the side.",
      "options": [
        "start",
        "center",
        "end"
      ],
      "default": "center"
    },
    "sideOffset": {
      "type": "number",
      "required": false,
      "description": "Offset from the trigger along the side axis (px).",
      "default": 8
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Called when the open state changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name for the content element."
    }
  },
  "states": [
    {
      "name": "Default (Tooltip)",
      "props": {
        "trigger": "hover",
        "content": "Tooltip text",
        "side": "top"
      }
    },
    {
      "name": "Popover (Click)",
      "props": {
        "trigger": "click",
        "interactive": true,
        "content": "Popover content",
        "side": "bottom"
      }
    },
    {
      "name": "Hover Card",
      "props": {
        "trigger": "hover",
        "interactive": true,
        "content": "Interactive hover card",
        "side": "bottom"
      }
    },
    {
      "name": "Right Side",
      "props": {
        "trigger": "hover",
        "content": "Right tooltip",
        "side": "right"
      }
    }
  ],
  "behavior": {
    "dismissOnEscape": true,
    "dismissOnClickOutside": true,
    "autoFocusOnOpen": "none"
  },
  "keyboard": {
    "Escape": {
      "action": "close"
    }
  },
  "aria": {
    "role": "tooltip"
  },
  "composition": {
    "required": [
      "root",
      "trigger",
      "content"
    ],
    "recommended": [
      "arrow"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "trigger": {
        "slot": "trigger",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "arrow": {
        "slot": "arrow",
        "parent": "content"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-overlay-content-max-w",
      "--uf-overlay-content-border-width",
      "--uf-responsive-overlay-zero-blur"
    ],
    "semanticFallbacks": [
      "--uf-membrane",
      "--uf-spacing-1",
      "--uf-spacing-2",
      "--uf-spacing-3",
      "--uf-radius",
      "--uf-font-size-xs",
      "--uf-font-size-sm",
      "--uf-font-weight",
      "--uf-color-primary",
      "--uf-color-primary-fg",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-border",
      "--uf-overlay-surface-blur",
      "--uf-overlay-enter-y",
      "--uf-overlay-enter-scale",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-z-overlay"
    ],
    "notes": [
      "Overlay trigger content is rendered through Button; string content is wrapped in Text.",
      "sideOffset and floating coordinates are positioning data produced by the floating adapter, not visual tokens.",
      "Hover overlays use primary surface tokens while interactive popovers use overlay surface tokens.",
      "Responsive overlay backdrops use --uf-responsive-overlay-zero-blur as the closed-state blur sentinel before open-state backdrop blur applies."
    ]
  },
  "platform": {
    "popover": true,
    "anchorPositioning": true
  },
  "usage": {
    "whenToUse": [
      "Background dimming for modals",
      "Click-outside dismiss layer"
    ],
    "whenNotToUse": [
      "Content display (use Modal or Drawer)",
      "Tooltip (use Tooltip)"
    ],
    "alternatives": [
      "Modal",
      "Drawer"
    ],
    "context": "app"
  }
}
