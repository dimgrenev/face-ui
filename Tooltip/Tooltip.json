{
  "name": "Tooltip",
  "description": "Non-interactive floating text hint anchored to a trigger element",
  "props": {
    "content": {
      "type": "string",
      "required": false,
      "description": "Content rendered inside the floating surface."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name for the content element."
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Trigger element (the anchor)."
    },
    "open": {
      "type": "boolean",
      "required": false,
      "description": "Controlled open state."
    },
    "openDelay": {
      "type": "number",
      "required": false,
      "description": "Delay before opening (ms).",
      "default": 300
    },
    "closeDelay": {
      "type": "number",
      "required": false,
      "description": "Delay before closing (ms).",
      "default": 0
    },
    "side": {
      "type": "enum",
      "required": false,
      "description": "Preferred side placement.",
      "options": ["top", "right", "bottom", "left"],
      "default": "top"
    },
    "align": {
      "type": "enum",
      "required": false,
      "description": "Alignment along the side.",
      "options": ["start", "center", "end"],
      "default": "center"
    },
    "sideOffset": {
      "type": "number",
      "required": false,
      "description": "Offset from the trigger along the side axis (px).",
      "default": 4
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Called when the open state changes."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "children": "Hover me",
        "content": "Tooltip text"
      }
    },
    {
      "name": "Bottom Placement",
      "props": {
        "children": "Hover me",
        "content": "Tooltip below",
        "side": "bottom"
      }
    }
  ],
  "behavior": {
    "dismissOnEscape": true,
    "autoFocusOnOpen": "none"
  },
  "keyboard": {
    "Escape": { "action": "close" }
  },
  "aria": {
    "role": "tooltip"
  },
  "composition": {
    "required": ["root", "trigger", "content"],
    "recommended": ["arrow"],
    "parts": {
      "root": { "slot": "root" },
      "trigger": { "slot": "trigger", "parent": "root" },
      "content": { "slot": "content", "parent": "root" },
      "arrow": { "slot": "arrow", "parent": "content" }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-overlay-content-max-w",
      "--uf-overlay-content-border-width"
    ],
    "semanticFallbacks": [
      "--uf-spacing-1",
      "--uf-spacing-2",
      "--uf-spacing-3",
      "--uf-radius",
      "--uf-membrane",
      "--uf-z-overlay",
      "--uf-duration-enter",
      "--uf-duration-exit",
      "--uf-ease-enter",
      "--uf-font-size-xs",
      "--uf-font-size-sm",
      "--uf-font-weight",
      "--uf-color-primary",
      "--uf-color-primary-fg",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-border",
      "--uf-overlay-surface-blur",
      "--uf-overlay-enter-y",
      "--uf-overlay-enter-scale"
    ],
    "notes": [
      "Tooltip is the non-interactive hover variant of Overlay.",
      "Tooltip copy must stay brief; use Popover for interactive or rich content."
    ]
  },
  "platform": {
    "popover": true,
    "anchorPositioning": true
  },
  "usage": {
    "whenToUse": [
      "Brief text hints on hover",
      "Icon button labels",
      "Abbreviated content expansion"
    ],
    "whenNotToUse": [
      "Rich content (use Popover)",
      "Interactive content (use Popover)",
      "Mobile-primary UI (tooltips need hover)"
    ],
    "alternatives": [
      "Popover"
    ],
    "context": "app"
  }
}
