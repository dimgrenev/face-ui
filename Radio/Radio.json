{
  "name": "Radio",
  "description": "Radio group for single-option selection",
  "props": {
    "options": {
      "type": "array",
      "required": true,
      "description": "Radio options to render.",
      "default": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ]
    },
    "value": {
      "type": "string",
      "required": false,
      "description": "Currently selected value."
    },
    "defaultValue": {
      "type": "string",
      "required": false,
      "description": "Uncontrolled initial selected value."
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Form field name."
    },
    "disabled": {
      "type": "boolean",
      "required": false,
      "description": "Disabled state for the entire group.",
      "default": false
    },
    "required": {
      "type": "boolean",
      "required": false,
      "description": "Mark as required.",
      "default": false
    },
    "orientation": {
      "type": "enum",
      "required": false,
      "description": "Layout orientation.",
      "options": [
        "horizontal",
        "vertical"
      ],
      "default": "vertical"
    },
    "onValueChange": {
      "type": "function",
      "required": false,
      "description": "Callback when value changes."
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional CSS class."
    },
    "membrane": {
      "type": "boolean",
      "required": false,
      "description": "Outer membrane wrapper (+1px outside each option geometry).",
      "default": true
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Horizontal",
      "props": {
        "orientation": "horizontal"
      }
    },
    {
      "name": "Disabled",
      "props": {
        "disabled": true
      }
    }
  ],
  "behavior": {
    "rovingFocus": true
  },
  "keyboard": {
    "ArrowDown": {
      "action": "focusNext"
    },
    "ArrowUp": {
      "action": "focusPrevious"
    },
    "ArrowRight": {
      "action": "focusNext"
    },
    "ArrowLeft": {
      "action": "focusPrevious"
    }
  },
  "aria": {
    "role": "radiogroup",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root",
      "item",
      "control",
      "indicator"
    ],
    "recommended": [
      "label"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "item": {
        "slot": "item",
        "parent": "root",
        "multiple": true
      },
      "control": {
        "slot": "control",
        "parent": "item"
      },
      "indicator": {
        "slot": "indicator",
        "parent": "control"
      },
      "label": {
        "slot": "label",
        "parent": "item"
      }
    }
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Mutually exclusive single selection",
      "Settings with few visible options",
      "Survey single-choice questions"
    ],
    "whenNotToUse": [
      "Multiple selections (use Checkbox)",
      "Many options (use Select)",
      "Binary toggle (use Switcher)"
    ],
    "alternatives": [
      "Select",
      "Checkbox",
      "Switcher",
      "SegmentedControl"
    ],
    "context": "both"
  }
}
