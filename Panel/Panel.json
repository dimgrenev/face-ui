{
  "name": "Panel",
  "description": "Collapsible panel navigation with nested groups",
  "props": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Panel item definitions (supports nested groups).",
      "default": [
        {
          "id": "dashboard",
          "label": "Dashboard"
        },
        {
          "id": "projects",
          "label": "Projects",
          "items": [
            {
              "id": "active",
              "label": "Active"
            },
            {
              "id": "archived",
              "label": "Archived"
            }
          ]
        },
        {
          "id": "settings",
          "label": "Settings"
        }
      ]
    },
    "collapsed": {
      "type": "boolean",
      "required": false,
      "description": "Whether the panel is collapsed."
    },
    "defaultCollapsed": {
      "type": "boolean",
      "required": false,
      "description": "Uncontrolled initial collapsed state.",
      "default": false
    },
    "onCollapsedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when collapsed state changes."
    },
    "selectedId": {
      "type": "string",
      "required": false,
      "description": "Currently selected item ID."
    },
    "defaultSelectedId": {
      "type": "string",
      "required": false,
      "description": "Uncontrolled initial selected item ID."
    },
    "onSelectedChange": {
      "type": "function",
      "required": false,
      "description": "Callback when selected item changes."
    },
    "width": {
      "type": "number",
      "required": false,
      "description": "Width when expanded.",
      "default": 260
    },
    "collapsedWidth": {
      "type": "number",
      "required": false,
      "description": "Width when collapsed.",
      "default": 60
    },
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name on the root element."
    },
    "previewPreset": {
      "type": "enum",
      "required": false,
      "description": "Showcase-only built-in layout preset.",
      "options": [
        "workspace"
      ]
    },
    "surface": {
      "type": "enum",
      "required": false,
      "description": "Surface behavior on compact viewports.",
      "options": [
        "auto",
        "inline",
        "sheet"
      ],
      "default": "auto"
    },
    "surfaceBreakpoint": {
      "type": "number",
      "required": false,
      "description": "Breakpoint where auto surfaces switch to sheet mode."
    },
    "open": {
      "type": "boolean",
      "required": false,
      "description": "Controlled drawer state for sheet mode."
    },
    "defaultOpen": {
      "type": "boolean",
      "required": false,
      "description": "Uncontrolled initial drawer state for sheet mode.",
      "default": false
    },
    "onOpenChange": {
      "type": "function",
      "required": false,
      "description": "Callback when drawer state changes."
    },
    "trigger": {
      "type": "string",
      "required": false,
      "description": "Optional trigger for sheet mode."
    },
    "surfaceTitle": {
      "type": "string",
      "required": false,
      "description": "Optional title used in compact sheet header."
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {}
    },
    {
      "name": "Collapsed",
      "props": {
        "collapsed": true
      }
    },
    {
      "name": "Custom Width",
      "props": {
        "width": 300
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "complementary",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root"
    ],
    "recommended": [
      "header",
      "content",
      "footer",
      "collapseButton"
    ],
    "parts": {
      "root": {
        "slot": "root"
      },
      "header": {
        "slot": "header",
        "parent": "root"
      },
      "content": {
        "slot": "content",
        "parent": "root"
      },
      "footer": {
        "slot": "footer",
        "parent": "root"
      },
      "collapseButton": {
        "slot": "collapseButton",
        "parent": "header"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-sidebar-preview-inset",
      "--uf-sidebar-preview-section-gap",
      "--uf-sidebar-preview-title-gap",
      "--face-runtime-sidebar-sheet-w",
      "--uf-sidebar-sheet-w-default",
      "--uf-sidebar-sheet-viewport-gap",
      "--uf-resizable-handle-size"
    ],
    "semanticFallbacks": [
      "--uf-content-inset",
      "--uf-membrane",
      "--uf-control-height",
      "--uf-control-pad-y",
      "--uf-control-pad-text",
      "--uf-control-gap",
      "--uf-font-size-sm",
      "--uf-font-weight",
      "--uf-font-weight-bold",
      "--uf-color-bg",
      "--uf-color-fg",
      "--uf-color-fg-muted",
      "--uf-color-hover-bg",
      "--uf-color-border"
    ],
    "notes": [
      "Panel uses Button, Icon and Text for item rendering and responsive sheet triggers.",
      "width and collapsedWidth are layout inputs; sheet width is bridged through --face-runtime-sidebar-sheet-w.",
      "Panel remains a higher-risk navigation primitive; behavior refactors require baseline coverage.",
      "Resizable panel handles use --uf-resizable-handle-size for the shared resizable machine CSS."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Sidebar content area",
      "Split-view detail pane",
      "Collapsible side section"
    ],
    "whenNotToUse": [
      "Overlay content (use Modal/Drawer)",
      "Simple content block (use Card)"
    ],
    "alternatives": [
      "Card",
      "Drawer",
      "Modal"
    ],
    "context": "app"
  }
}
