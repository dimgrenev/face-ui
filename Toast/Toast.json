{
  "name": "Toast",
  "description": "Notification system with toaster singleton and factory",
  "props": {
    "className": {
      "type": "string",
      "required": false,
      "description": "Additional class name for the toast group container.",
      "default": null
    },
    "showTrigger": {
      "type": "boolean",
      "required": false,
      "description": "Show explicit trigger button in preview/demo wrapper.",
      "default": true
    },
    "autoShow": {
      "type": "boolean",
      "required": false,
      "description": "Automatically show one sample toast after mount.",
      "default": false
    }
  },
  "states": [
    {
      "name": "Default (Trigger Button)",
      "props": {}
    },
    {
      "name": "Auto Show",
      "props": {
        "showTrigger": false,
        "autoShow": true
      }
    }
  ],
  "behavior": {
    "dismissOnEscape": true,
    "autoFocusOnOpen": "none"
  },
  "keyboard": {
    "Escape": { "action": "dismissAll" }
  },
  "aria": {
    "role": "status",
    "live": "polite",
    "variantRolePolicy": "All toast variants stay non-blocking polite status messages. Use Modal or alertdialog for blocking alerts."
  },
  "composition": {
    "required": ["root", "group", "item"],
    "recommended": ["title", "description", "action", "close"],
    "parts": {
      "root": { "slot": "root" },
      "group": { "slot": "group", "parent": "root" },
      "item": { "slot": "item", "parent": "group", "multiple": true },
      "title": { "slot": "title", "parent": "item" },
      "description": { "slot": "description", "parent": "item" },
      "action": { "slot": "action", "parent": "item" },
      "close": { "slot": "close", "parent": "item" }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-toast-container-max-width",
      "--uf-toast-surface-pad",
      "--uf-toast-border-width",
      "--uf-toast-compact-inset"
    ],
    "semanticFallbacks": [
      "--uf-control-height",
      "--uf-radius-md",
      "--uf-font-size",
      "--uf-font-size-sm",
      "--uf-font-weight-bold",
      "--uf-color-fg-muted",
      "--uf-overlay-surface-bg",
      "--uf-overlay-surface-border",
      "--uf-overlay-surface-blur",
      "--uf-overlay-surface-shadow"
    ],
    "notes": [
      "Toast content uses Text and Bar/Button primitives internally; do not create toast-local typography classes for new copy.",
      "The toaster z-index remains an implementation detail until a global layer token is introduced."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Success/error notifications",
      "Non-blocking status messages",
      "Action confirmations"
    ],
    "whenNotToUse": [
      "Blocking alerts (use Modal)",
      "Inline validation (use Input error prop)"
    ],
    "alternatives": ["Modal"],
    "context": "app"
  }
}
