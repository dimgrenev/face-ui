{
  "name": "Badge",
  "description": "Status indicator label",
  "props": {
    "text": {
      "type": "string",
      "required": false,
      "description": "Badge text content",
      "default": null
    },
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Visual style variant",
      "options": [
        "default",
        "primary",
        "secondary",
        "accent",
        "destructive",
        "outline"
      ],
      "default": "default"
    },
    "appearance": {
      "type": "enum",
      "required": false,
      "description": "Fill or outline appearance",
      "options": [
        "fill",
        "outline"
      ],
      "default": "fill"
    },
    "children": {
      "type": "string",
      "required": false,
      "description": "Custom children content (overrides text)",
      "default": null
    }
  },
  "states": [
    {
      "name": "Default",
      "props": {
        "text": "Badge"
      }
    },
    {
      "name": "Primary",
      "props": {
        "text": "Primary",
        "variant": "primary"
      }
    },
    {
      "name": "Secondary",
      "props": {
        "text": "Secondary",
        "variant": "secondary"
      }
    },
    {
      "name": "Accent",
      "props": {
        "text": "Accent",
        "variant": "accent"
      }
    },
    {
      "name": "Outline",
      "props": {
        "text": "Outline",
        "variant": "default",
        "appearance": "outline"
      }
    },
    {
      "name": "Destructive",
      "props": {
        "text": "Destructive",
        "variant": "destructive"
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "status"
  },
  "composition": {
    "required": [
      "root"
    ],
    "parts": {
      "root": {
        "slot": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [
      "--uf-badge-outline-width",
      "--uf-badge-bg",
      "--uf-badge-fg",
      "--uf-badge-border"
    ],
    "semanticFallbacks": [
      "--uf-membrane",
      "--uf-control-pad-icon",
      "--uf-control-line-height",
      "--uf-font-size-xs",
      "--uf-font-weight-bold",
      "--uf-radius-full",
      "--uf-color-primary",
      "--uf-color-primary-fg",
      "--uf-color-hover-bg",
      "--uf-color-fg",
      "--uf-color-border",
      "--uf-color-destructive",
      "--uf-color-destructive-fg",
      "--uf-color-accent",
      "--uf-color-accent-fg"
    ],
    "notes": [
      "Badge content renders through Text with inset=control and membrane enabled.",
      "Variant tokens are local aliases over semantic intent colors."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Status indicators",
      "Count notifications",
      "Category labels/tags"
    ],
    "whenNotToUse": [
      "Action buttons (use Button)",
      "Large informational blocks (use Card)"
    ],
    "alternatives": [
      "Text",
      "Button"
    ],
    "context": "both"
  }
}
