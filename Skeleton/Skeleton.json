{
  "name": "Skeleton",
  "description": "Loading placeholder with animation",
  "props": {
    "width": {
      "type": "string",
      "required": false,
      "description": "Explicit width",
      "default": "200px"
    },
    "height": {
      "type": "string",
      "required": false,
      "description": "Explicit height",
      "default": "20px"
    },
    "variant": {
      "type": "enum",
      "required": false,
      "description": "Shape variant",
      "options": [
        "text",
        "circle",
        "rect"
      ],
      "default": "text"
    }
  },
  "states": [
    {
      "name": "Default (Text)",
      "props": {}
    },
    {
      "name": "Circle",
      "props": {
        "variant": "circle",
        "width": "48px",
        "height": "48px"
      }
    },
    {
      "name": "Rectangle",
      "props": {
        "variant": "rect",
        "width": "200px",
        "height": "120px"
      }
    },
    {
      "name": "Custom Size",
      "props": {
        "width": "300px",
        "height": "20px"
      }
    }
  ],
  "behavior": {},
  "keyboard": {},
  "aria": {
    "role": "progressbar",
    "required": [
      "aria-label"
    ]
  },
  "composition": {
    "required": [
      "root"
    ],
    "parts": {
      "root": {
        "slot": "root"
      }
    }
  },
  "tokenMapping": {
    "component": [],
    "semanticFallbacks": [
      "--uf-color-hover-bg",
      "--uf-radius",
      "--uf-radius-full",
      "--uf-control-height",
      "--uf-motion-duration-skeleton",
      "--uf-motion-iteration-indefinite",
      "--uf-motion-ease-in-out"
    ],
    "notes": [
      "Width and height are product layout inputs passed through style for placeholder fitting.",
      "Pulse keyframes stay component-local while animation duration and easing consume shared Face UI motion tokens."
    ]
  },
  "platform": {},
  "usage": {
    "whenToUse": [
      "Loading placeholder for content",
      "Shimmer effect while fetching",
      "Layout preview before data loads"
    ],
    "whenNotToUse": [
      "Known progress percentage (use Progress)",
      "Simple spinner"
    ],
    "alternatives": [
      "Progress"
    ],
    "context": "both"
  }
}
